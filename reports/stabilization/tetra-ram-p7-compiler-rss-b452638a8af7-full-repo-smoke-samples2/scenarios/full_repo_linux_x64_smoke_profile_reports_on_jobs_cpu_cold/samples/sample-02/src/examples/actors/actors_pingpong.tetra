// Actors smoke test (linux-x64)
// Spawns a pong actor, sends a value, waits for response.
func pong() -> i32
uses actors:
    var v: i32 = core.recv()
    if v == 41:
        var _sent: i32 = core.send(core.sender(), 42)
        return 0
    return 1

func main() -> i32
uses actors:
    var p: actor = core.spawn("pong")
    var _sent: i32 = core.send(p, 41)
    var r: i32 = core.recv()
    if r == 42:
        return 0
    return 1
