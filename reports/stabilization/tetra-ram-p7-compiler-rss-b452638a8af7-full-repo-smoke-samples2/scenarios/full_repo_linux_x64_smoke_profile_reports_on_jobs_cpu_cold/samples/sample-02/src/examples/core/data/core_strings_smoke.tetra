// Stable core strings stdlib smoke.
module examples.core.data.core_strings_smoke

import lib.core.strings as strings

func main() -> Int:
    if strings.ascii_len("*") != 1:
        return 10
    if !strings.is_empty(""):
        return 20
    if strings.is_empty("*"):
        return 30
    return strings.ascii_sum("*")
