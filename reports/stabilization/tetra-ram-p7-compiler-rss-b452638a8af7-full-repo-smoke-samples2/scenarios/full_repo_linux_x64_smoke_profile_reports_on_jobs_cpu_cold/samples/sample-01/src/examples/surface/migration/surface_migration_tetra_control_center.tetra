        let status_bar: surface.Rect = surface.Rect(x: 250, y: 704, w: 880, h: 32)
        let bg: surface.Color = surface.Color(r: 16, g: 18, b: 22, a: 255)
        let nav: surface.Color = surface.Color(r: 31, g: 36, b: 43, a: 255)
        let panel: surface.Color = surface.Color(r: 44, g: 52, b: 61, a: 255)
        let accent: surface.Color = surface.Color(r: 76, g: 154, b: 185, a: 255)
        let warning: surface.Color = surface.Color(r: 224, g: 163, b: 62, a: 255)
        let text: surface.Color = surface.Color(r: 231, g: 237, b: 244, a: 255)
        let clear_status: Int = draw.clear(ctx, bg)
        let nav_status: Int = draw.rect(ctx, surface.Rect(x: 0, y: 0, w: 220, h: 760), nav)
        let title_status: Int = draw.text(ctx, "Tetra Control Center", 24, 24, text)
        let dashboard_status: Int = draw.rect_outline(ctx, dashboard_tab, text)
        let profiles_status: Int = draw.rect_outline(ctx, profiles_tab, accent)
        let fans_status: Int = draw.rect_outline(ctx, fans_tab, text)
        let diagnostics_status: Int = draw.rect_outline(ctx, diagnostics_tab, text)
        let logs_status: Int = draw.rect_outline(ctx, logs_tab, text)
        let settings_status: Int = draw.rect_outline(ctx, settings_tab, text)
        let body_status: Int = draw.rect(ctx, surface.Rect(x: 250, y: 32, w: 880, h: 670), panel)
        let active_status: Int = draw.text(ctx, "activeScreenText", 280, 60, text)
        let profile_status: Int = draw.text(ctx, "selectedProfileText", 280, 92, accent)
        let request_status: Int = draw.text(ctx, "profileRequestText", 280, 124, text)
        let dry_run_status: Int = draw.text(ctx, "dryRunText", 280, 156, warning)
        let action_status: Int = draw.text(ctx, "lastActionText", 280, 188, text)
        let quiet_status: Int = draw.rect_outline(ctx, quiet_button, text)
        let balanced_status: Int = draw.rect_outline(ctx, balanced_button, accent)
        let performance_status: Int = draw.rect_outline(ctx, performance_button, warning)
        let custom_status: Int = draw.rect_outline(ctx, custom_button, text)
        let dry_run_button_status: Int = draw.rect(ctx, dry_run_button, warning)
        let refresh_status: Int = draw.rect(ctx, refresh_button, accent)
        let command_status: Int = draw.rect_outline(ctx, command_button, accent)
        let dialog_status: Int = draw.rect_outline(ctx, blocked_dialog_button, warning)
        let settings_edit_status: Int = draw.rect_outline(ctx, settings_edit_button, text)
        let log_row_status: Int = draw.rect_outline(ctx, log_row_button, text)
        let error_retry_status: Int = draw.rect_outline(ctx, error_retry_button, warning)
        let status_bar_status: Int = draw.rect(ctx, status_bar, nav)
        let command_text_status: Int = draw.text(ctx, "commandPaletteSurface", 660, 328, text)
        let settings_text_status: Int = draw.text(ctx, "settingsEditSurface", 292, 394, text)
        let log_text_status: Int = draw.text(ctx, "logOutputSurface", 292, 450, text)
        let error_text_status: Int = draw.text(ctx, "retryErrorSurface", 668, 450, text)
        let status_text_status: Int = draw.text(ctx, "appShellStatusSurface", 268, 712, text)
        let nav_draw: Int = clear_status + nav_status + title_status
        let tab_draw: Int = dashboard_status + profiles_status + fans_status
        let tab_tail_draw: Int = diagnostics_status + logs_status + settings_status
        let content_draw: Int = body_status + active_status + profile_status
        let content_tail: Int = request_status + dry_run_status + action_status
        let profile_draw: Int = quiet_status + balanced_status + performance_status + custom_status
        let action_draw: Int = dry_run_button_status + refresh_status + command_status
        let dialog_draw: Int = dialog_status + settings_edit_status + log_row_status
        let error_draw: Int = error_retry_status + status_bar_status
        let text_draw: Int = command_text_status + settings_text_status + log_text_status
        let text_tail_draw: Int = error_text_status + status_text_status
        let state_count: Int = self.refreshCount + self.settingsEditCount + self.selectedLog
        let retry_count: Int = self.errorRetryCount + bool_count(self.commandPaletteOpen)
        let dialog_count: Int = bool_count(self.blockedDialogOpen)
        let draw_head: Int = nav_draw + tab_draw + tab_tail_draw + content_draw
        let draw_mid: Int = content_tail + profile_draw + action_draw + dialog_draw
        let draw_tail: Int = error_draw + text_draw + text_tail_draw
        return draw_head + draw_mid + draw_tail + state_count + retry_count + dialog_count
    func event(self: inout ControlCenterSurface, event: surface.Event) -> Int:
        let dashboard_tab: surface.Rect = surface.Rect(x: 24, y: 80, w: 160, h: 36)
        let profiles_tab: surface.Rect = surface.Rect(x: 24, y: 124, w: 160, h: 36)
        let fans_tab: surface.Rect = surface.Rect(x: 24, y: 168, w: 160, h: 36)
        let diagnostics_tab: surface.Rect = surface.Rect(x: 24, y: 212, w: 160, h: 36)
        let logs_tab: surface.Rect = surface.Rect(x: 24, y: 256, w: 160, h: 36)
        let settings_tab: surface.Rect = surface.Rect(x: 24, y: 300, w: 160, h: 36)
        let quiet_button: surface.Rect = surface.Rect(x: 280, y: 248, w: 120, h: 36)
        let balanced_button: surface.Rect = surface.Rect(x: 416, y: 248, w: 120, h: 36)
        let performance_button: surface.Rect = surface.Rect(x: 552, y: 248, w: 140, h: 36)
        let custom_button: surface.Rect = surface.Rect(x: 708, y: 248, w: 120, h: 36)
        let dry_run_button: surface.Rect = surface.Rect(x: 280, y: 316, w: 160, h: 40)
        let refresh_button: surface.Rect = surface.Rect(x: 456, y: 316, w: 160, h: 40)
        let command_button: surface.Rect = surface.Rect(x: 648, y: 316, w: 160, h: 40)
        let blocked_dialog_button: surface.Rect = surface.Rect(x: 812, y: 316, w: 180, h: 40)
        let settings_edit_button: surface.Rect = surface.Rect(x: 280, y: 384, w: 180, h: 36)
        let log_row_button: surface.Rect = surface.Rect(x: 280, y: 440, w: 360, h: 36)
        let error_retry_button: surface.Rect = surface.Rect(x: 656, y: 440, w: 140, h: 36)
        if event.kind != surface.event_mouse_up():
            return 0
        if rect_contains(dashboard_tab, event.x, event.y):
            self.activeScreen = 1
            return 1
        if rect_contains(profiles_tab, event.x, event.y):
            self.activeScreen = 2
            return 1
        if rect_contains(fans_tab, event.x, event.y):
            self.activeScreen = 3
            return 1
        if rect_contains(diagnostics_tab, event.x, event.y):
            self.activeScreen = 4
            return 1
        if rect_contains(logs_tab, event.x, event.y):
            self.activeScreen = 5
            return 1
        if rect_contains(settings_tab, event.x, event.y):
            self.activeScreen = 6
            return 1
        if rect_contains(quiet_button, event.x, event.y):
            self.selectedProfile = 1
            return 1
        if rect_contains(balanced_button, event.x, event.y):
            self.selectedProfile = 2
            return 1
        if rect_contains(performance_button, event.x, event.y):
            self.selectedProfile = 3
            return 1
        if rect_contains(custom_button, event.x, event.y):
            self.selectedProfile = 4
            return 1
        if rect_contains(dry_run_button, event.x, event.y):
            if self.dryRunEnabled:
                self.dryRunEnabled = false
            else:
                self.dryRunEnabled = true
            return 1
        if rect_contains(refresh_button, event.x, event.y):
            self.refreshCount = self.refreshCount + 1
            return 1
        if rect_contains(command_button, event.x, event.y):
            self.commandPaletteOpen = true
            self.activeScreen = 7
            return 1
        if rect_contains(blocked_dialog_button, event.x, event.y):
            self.blockedDialogOpen = true
            return 1
        if rect_contains(settings_edit_button, event.x, event.y):
            self.activeScreen = 6
            self.settingsEditCount = self.settingsEditCount + 1
            return 1
        if rect_contains(log_row_button, event.x, event.y):
            self.activeScreen = 5
            self.selectedLog = 1
            return 1
        if rect_contains(error_retry_button, event.x, event.y):
            self.activeScreen = 4
            self.errorRetryCount = self.errorRetryCount + 1
            return 1
        return 0

func flagship_root_block(rect: surface.Rect) -> block.Block:
    let paint: block.PaintSpec = block.paint_stack2(block.paint_layer_fill_radius(morph.theme_dark(), 0), block.paint_layer_overlay(morph.accent(), 42, 0))
    let props: block.BlockProps = block.props(block.layout_overlay(rect, 0), paint, block.text_none(), block.image_none(), block.input_none(), block.event_none(), block.state_base(), block.motion_none(), block.accessibility_region(24), block.asset_none())
    return block.make(block.id(1), block.id_none(), props)

func build_flagship_recipe_evidence(active_screen: Int, selected_profile: Int, dry_run: Bool, refresh_count: Int, command_open: Bool, settings_edit_count: Int, selected_log: Int, error_retry_count: Int, blocked_dialog_open: Bool) -> FlagshipRecipeEvidence
uses alloc, mem:
    let root_rect: surface.Rect = surface.Rect(x: 0, y: 0, w: 1180, h: 760)
    let shell_rect: surface.Rect = surface.Rect(x: 0, y: 0, w: 1180, h: 760)
    let nav_rect: surface.Rect = surface.Rect(x: 24, y: 80, w: 160, h: 256)
    let toolbar_rect: surface.Rect = surface.Rect(x: 250, y: 32, w: 880, h: 44)
    let dashboard_rect: surface.Rect = surface.Rect(x: 250, y: 92, w: 420, h: 190)
