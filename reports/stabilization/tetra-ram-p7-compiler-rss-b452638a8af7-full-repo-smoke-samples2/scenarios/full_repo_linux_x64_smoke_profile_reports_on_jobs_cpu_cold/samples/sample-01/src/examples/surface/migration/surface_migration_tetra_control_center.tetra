    let empty_rect: surface.Rect = surface.Rect(x: 456, y: 204, w: 180, h: 36)
    let rebuild_rect: surface.Rect = surface.Rect(x: 456, y: 316, w: 160, h: 40)
    let profile_rect: surface.Rect = surface.Rect(x: 552, y: 248, w: 140, h: 36)
    let state_rect: surface.Rect = surface.Rect(x: 690, y: 316, w: 220, h: 32)
    let app_shell_recipe: morph.Recipe = morph.recipe_app_shell()
    let nav_recipe: morph.Recipe = morph.recipe_nav_item()
    let toolbar_recipe: morph.Recipe = morph.recipe_toolbar()
    let tab_recipe: morph.Recipe = morph.recipe_tab_item()
    let split_recipe: morph.Recipe = morph.recipe_split_pane()
    let status_recipe: morph.Recipe = morph.recipe_status_bar()
    let command_recipe: morph.Recipe = morph.recipe_command_item()
    let settings_recipe: morph.Recipe = morph.recipe_settings_form()
    let log_recipe: morph.Recipe = morph.recipe_log_row()
    let metric_recipe: morph.Recipe = morph.recipe_metric_tile()
    let toast_recipe: morph.Recipe = morph.recipe_toast_notification()
    let dialog_recipe: morph.Recipe = morph.recipe_dialog_panel()
    let empty_recipe: morph.Recipe = morph.recipe_empty_state()
    let error_recipe: morph.Recipe = morph.recipe_error_panel()
    let action_recipe: morph.Recipe = morph.recipe_control_action()
    let region_recipe: morph.Recipe = morph.recipe_region_panel()
    var tree: block.BlockTree = block.tree_init(24)
    let root: Int = block.tree_add_root(tree, flagship_root_block(root_rect), root_rect)
    let parent_root: block.BlockID = block.id(1)
    let parent_shell: block.BlockID = block.id(2)
    let parent_dashboard: block.BlockID = block.id(5)
    let shell_block: block.Block = morph.expand_region_panel(2, 1, shell_rect, 18)
    let shell: Int = block.tree_add_child(tree, parent_root, shell_block, shell_rect)
    let nav_active: Bool = active_screen == 2
    let nav_block: block.Block = morph.expand_control_action(3, 2, nav_rect, 10, 1401, nav_active)
    let nav: Int = block.tree_add_child(tree, parent_shell, nav_block, nav_rect)
    let tb: block.Block = morph.expand_control_action(4, 2, toolbar_rect, 12, 1402, command_open)
    let toolbar: Int = block.tree_add_child(tree, parent_shell, tb, toolbar_rect)
    let dashboard_block: block.Block = morph.expand_region_panel(5, 2, dashboard_rect, 16)
    let dashboard: Int = block.tree_add_child(tree, parent_shell, dashboard_block, dashboard_rect)
    let command_block: block.Block = morph.expand_field_text(6, 5, 18, command_rect, 18, 8)
    let command: Int = block.tree_add_child(tree, parent_dashboard, command_block, command_rect)
    let settings_block: block.Block = morph.expand_field_text(7, 5, 18, settings_rect, 18, 8)
    let settings: Int = block.tree_add_child(tree, parent_dashboard, settings_block, settings_rect)
    let log_active: Bool = selected_log > 0
    let logs_block: block.Block = morph.expand_control_action(8, 5, logs_rect, 14, 1403, log_active)
    let logs: Int = block.tree_add_child(tree, parent_dashboard, logs_block, logs_rect)
    let status_block: block.Block = morph.expand_label(9, 2, 6, status_rect, 18)
    let status: Int = block.tree_add_child(tree, parent_shell, status_block, status_rect)
    let error_active: Bool = error_retry_count > 0
    let eb: block.Block = morph.expand_control_action(10, 5, error_rect, 13, 1404, error_active)
    let error: Int = block.tree_add_child(tree, parent_dashboard, eb, error_rect)
    let dialog_block: block.Block = morph.expand_region_panel(11, 2, dialog_rect, 20)
    let dialog: Int = block.tree_add_child(tree, parent_shell, dialog_block, dialog_rect)
    let metric_b: block.Block = morph.expand_control_action(12, 5, metric_rect, 12, 1405, dry_run)
    let metric: Int = block.tree_add_child(tree, parent_dashboard, metric_b, metric_rect)
    let toast_active: Bool = refresh_count > 0
    let tt: block.Block = morph.expand_control_action(13, 5, toast_rect, 15, 1406, toast_active)
    let toast: Int = block.tree_add_child(tree, parent_dashboard, tt, toast_rect)
    let tab_active: Bool = active_screen == 5
    let tab_block: block.Block = morph.expand_control_action(14, 5, tab_rect, 10, 1407, tab_active)
    let tab: Int = block.tree_add_child(tree, parent_dashboard, tab_block, tab_rect)
    let empty_block: block.Block = morph.expand_control_action(15, 5, empty_rect, 11, 1408, false)
    let empty: Int = block.tree_add_child(tree, parent_dashboard, empty_block, empty_rect)
    let rb: block.Block = morph.expand_control_action(16, 5, rebuild_rect, 14, 1409, toast_active)
    let rebuild: Int = block.tree_add_child(tree, parent_dashboard, rb, rebuild_rect)
    let profile_active: Bool = selected_profile == 3
    let pb: block.Block = morph.expand_control_action(17, 5, profile_rect, 12, 1410, profile_active)
    let profile: Int = block.tree_add_child(tree, parent_dashboard, pb, profile_rect)
    let app_state_block: block.Block = morph.expand_label(18, 2, 7, state_rect, 18)
    let app_state: Int = block.tree_add_child(tree, parent_shell, app_state_block, state_rect)
    let id2: block.BlockID = block.id(2)
    let id3: block.BlockID = block.id(3)
    let id4: block.BlockID = block.id(4)
    let id5: block.BlockID = block.id(5)
    let id6: block.BlockID = block.id(6)
    let id7: block.BlockID = block.id(7)
    let id8: block.BlockID = block.id(8)
    let id9: block.BlockID = block.id(9)
    let id10: block.BlockID = block.id(10)
    let id11: block.BlockID = block.id(11)
    let id12: block.BlockID = block.id(12)
    let id13: block.BlockID = block.id(13)
    let id14: block.BlockID = block.id(14)
    let id15: block.BlockID = block.id(15)
    let id16: block.BlockID = block.id(16)
    let app_shell_expansion: morph.RecipeExpansion = morph.recipe_expansion(app_shell_recipe, id2)
    let nav_expansion: morph.RecipeExpansion = morph.recipe_expansion(nav_recipe, id3)
    let toolbar_expansion: morph.RecipeExpansion = morph.recipe_expansion(toolbar_recipe, id4)
    let tab_expansion: morph.RecipeExpansion = morph.recipe_expansion(tab_recipe, id14)
    let split_expansion: morph.RecipeExpansion = morph.recipe_expansion(split_recipe, id5)
    let status_expansion: morph.RecipeExpansion = morph.recipe_expansion(status_recipe, id9)
    let command_expansion: morph.RecipeExpansion = morph.recipe_expansion(command_recipe, id6)
    let settings_expansion: morph.RecipeExpansion = morph.recipe_expansion(settings_recipe, id7)
    let log_expansion: morph.RecipeExpansion = morph.recipe_expansion(log_recipe, id8)
    let metric_expansion: morph.RecipeExpansion = morph.recipe_expansion(metric_recipe, id12)
    let toast_expansion: morph.RecipeExpansion = morph.recipe_expansion(toast_recipe, id13)
    let dialog_expansion: morph.RecipeExpansion = morph.recipe_expansion(dialog_recipe, id11)
    let empty_expansion: morph.RecipeExpansion = morph.recipe_expansion(empty_recipe, id15)
    let error_expansion: morph.RecipeExpansion = morph.recipe_expansion(error_recipe, id10)
    let action_expansion: morph.RecipeExpansion = morph.recipe_expansion(action_recipe, id16)
    let region_expansion: morph.RecipeExpansion = morph.recipe_expansion(region_recipe, id5)
    let recipe_shell_ok: Bool = morph.recipe_expands_to_block(app_shell_recipe)
    let recipe_nav_ok: Bool = morph.recipe_expands_to_block(nav_recipe)
    let recipe_toolbar_ok: Bool = morph.recipe_expands_to_block(toolbar_recipe)
    let recipe_tab_ok: Bool = morph.recipe_expands_to_block(tab_recipe)
    let recipe_split_ok: Bool = morph.recipe_expands_to_block(split_recipe)
    let recipe_status_ok: Bool = morph.recipe_expands_to_block(status_recipe)
    let recipe_command_ok: Bool = morph.recipe_expands_to_block(command_recipe)
    let recipe_settings_ok: Bool = morph.recipe_expands_to_block(settings_recipe)
    let recipe_log_ok: Bool = morph.recipe_expands_to_block(log_recipe)
    let recipe_metric_ok: Bool = morph.recipe_expands_to_block(metric_recipe)
    let recipe_toast_ok: Bool = morph.recipe_expands_to_block(toast_recipe)
    let recipe_dialog_ok: Bool = morph.recipe_expands_to_block(dialog_recipe)
    let recipe_empty_ok: Bool = morph.recipe_expands_to_block(empty_recipe)
    let recipe_error_ok: Bool = morph.recipe_expands_to_block(error_recipe)
    let recipe_action_ok: Bool = morph.recipe_expands_to_block(action_recipe)
    let recipe_region_ok: Bool = morph.recipe_expands_to_block(region_recipe)
    let recipes_safe_a1: Bool = recipe_shell_ok && recipe_nav_ok
    let recipes_safe_a2: Bool = recipe_toolbar_ok && recipe_tab_ok
    let recipes_safe_a: Bool = recipes_safe_a1 && recipes_safe_a2
    let recipes_safe_b: Bool = recipe_split_ok && recipe_status_ok && recipe_command_ok
    let recipes_safe_c: Bool = recipe_settings_ok && recipe_log_ok && recipe_metric_ok
    let recipes_safe_d: Bool = recipe_toast_ok && recipe_dialog_ok && recipe_empty_ok
    let recipes_safe_e: Bool = recipe_error_ok && recipe_action_ok && recipe_region_ok
    let recipes_safe_head: Bool = recipes_safe_a && recipes_safe_b && recipes_safe_c
    let recipes_safe_tail: Bool = recipes_safe_d && recipes_safe_e
    let recipes_safe: Bool = recipes_safe_head && recipes_safe_tail
    let app_shell_ok: Bool = morph.expansion_valid(app_shell_expansion)
    let nav_ok: Bool = morph.expansion_valid(nav_expansion)
    let toolbar_ok: Bool = morph.expansion_valid(toolbar_expansion)
    let tab_ok: Bool = morph.expansion_valid(tab_expansion)
