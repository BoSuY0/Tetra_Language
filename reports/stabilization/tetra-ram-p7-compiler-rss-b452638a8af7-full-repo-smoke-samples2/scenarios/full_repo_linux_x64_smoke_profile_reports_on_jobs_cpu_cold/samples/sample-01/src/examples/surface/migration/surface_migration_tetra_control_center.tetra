// Pure Tetra Surface migration of examples/projects/tetra_control_center/src/main.tetra.
module examples.surface.migration.surface_migration_tetra_control_center

import lib.core.surface as surface
import lib.core.draw as draw
import lib.core.block as block
import lib.core.morph as morph

struct ControlCenterSurface:
    activeScreen: Int
    selectedProfile: Int
    dryRunEnabled: Bool
    refreshCount: Int
    commandPaletteOpen: Bool
    settingsEditCount: Int
    selectedLog: Int
    errorRetryCount: Int
    blockedDialogOpen: Bool

struct FlagshipRecipeEvidence:
    recipe_count: Int
    block_count: Int
    product_surface_count: Int
    interaction_count: Int
    app_shell_state_count: Int
    tree_status: Int
    recipes_safe: Bool
    expansions_valid: Bool
    a11y_projection: Bool

extension ControlCenterSurface:
    func draw(self: borrow ControlCenterSurface, ctx: inout draw.DrawContext) -> Int
    uses mem:
