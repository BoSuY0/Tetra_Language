    let status_ok: Bool = morph.expansion_valid(status_expansion)
    let command_ok: Bool = morph.expansion_valid(command_expansion)
    let settings_ok: Bool = morph.expansion_valid(settings_expansion)
    let log_ok: Bool = morph.expansion_valid(log_expansion)
    let metric_ok: Bool = morph.expansion_valid(metric_expansion)
    let toast_ok: Bool = morph.expansion_valid(toast_expansion)
    let dialog_ok: Bool = morph.expansion_valid(dialog_expansion)
    let empty_ok: Bool = morph.expansion_valid(empty_expansion)
    let error_ok: Bool = morph.expansion_valid(error_expansion)
    let action_ok: Bool = morph.expansion_valid(action_expansion)
    let region_ok: Bool = morph.expansion_valid(region_expansion)
    let expansion_a: Bool = app_shell_ok && nav_ok && toolbar_ok && tab_ok
    let expansion_b: Bool = split_ok && status_ok && command_ok && settings_ok
    let expansion_c: Bool = log_ok && metric_ok && toast_ok && dialog_ok
    let expansion_d: Bool = empty_ok && error_ok && action_ok && region_ok
    let expansions_valid: Bool = expansion_a && expansion_b && expansion_c && expansion_d
    let state_count_a: Int = active_screen + selected_profile + refresh_count
    let state_count_b: Int = settings_edit_count + selected_log + error_retry_count
    let app_shell_state_count: Int = state_count_a + state_count_b
    let blocked_dialog_count: Int = bool_count(blocked_dialog_open)
    let interaction_a: Int = refresh_count + settings_edit_count + selected_log
    let interaction_b: Int = error_retry_count + bool_count(command_open)
    let interaction_c: Int = blocked_dialog_count + selected_profile
    let interaction_count: Int = interaction_a + interaction_b + interaction_c
    let valid: Int = block.tree_validate(tree)
    let shell_ok: Bool = root == 1 && shell == 2 && nav == 3 && toolbar == 4
    let dashboard_ok: Bool = dashboard == 5 && command == 6 && settings == 7 && logs == 8
    let status_ids_ok: Bool = status == 9 && error == 10 && dialog == 11
    let metrics_ok: Bool = metric == 12 && toast == 13 && tab == 14 && empty == 15
    let action_ids_ok: Bool = rebuild == 16 && profile == 17 && app_state == 18
    if shell_ok && dashboard_ok && status_ids_ok && metrics_ok && action_ids_ok:
        return FlagshipRecipeEvidence(recipe_count: 16, block_count: block.tree_len(tree), product_surface_count: 9, interaction_count: interaction_count, app_shell_state_count: app_shell_state_count, tree_status: valid, recipes_safe: recipes_safe, expansions_valid: expansions_valid, a11y_projection: morph.accessibility_projection_ok(18, 7, 18))
    return FlagshipRecipeEvidence(recipe_count: 0, block_count: block.tree_len(tree), product_surface_count: 0, interaction_count: interaction_count, app_shell_state_count: app_shell_state_count, tree_status: valid, recipes_safe: false, expansions_valid: false, a11y_projection: false)

func bool_count(value: Bool) -> Int:
    if value:
        return 1
    return 0

func flagship_recipe_ready(evidence: FlagshipRecipeEvidence) -> Int:
    let count_ok: Bool = evidence.recipe_count == 16 && evidence.block_count == 18
    let surface_ok: Bool = evidence.product_surface_count >= 9 && evidence.interaction_count >= 8
    let state_ok: Bool = evidence.app_shell_state_count > 0
    let tree_ok: Bool = evidence.tree_status == block.tree_error_ok()
    let recipe_ok: Bool = evidence.recipes_safe && evidence.expansions_valid
    let a11y_ok: Bool = evidence.a11y_projection && morph.capsule_self_check()
    if count_ok && surface_ok && state_ok && tree_ok && recipe_ok && a11y_ok:
        return 0
    return 1

func rect_contains(rect: surface.Rect, x: Int, y: Int) -> Bool:
    return x >= rect.x && y >= rect.y && x < rect.x + rect.w && y < rect.y + rect.h

func main() -> Int
uses alloc, mem, surface:
    var app: ControlCenterSurface = ControlCenterSurface(activeScreen: 1, selectedProfile: 2, dryRunEnabled: true, refreshCount: 0, commandPaletteOpen: false, settingsEditCount: 0, selectedLog: 0, errorRetryCount: 0, blockedDialogOpen: false)
    var win: surface.Surface = surface.open("Surface Migration Control Center", 1180, 760)
    let open_profiles: surface.Event = surface.Event(kind: surface.event_mouse_up(), x: 48, y: 140, button: 1, key: 0, width: 1180, height: 760, timestamp_ms: 1, text_len: 0)
    let profiles_status: Int = ControlCenterSurface.event(app, open_profiles)
    let choose_performance: surface.Event = surface.Event(kind: surface.event_mouse_up(), x: 580, y: 264, button: 1, key: 0, width: 1180, height: 760, timestamp_ms: 2, text_len: 0)
    let performance_status: Int = ControlCenterSurface.event(app, choose_performance)
    let toggle_dry_run: surface.Event = surface.Event(kind: surface.event_mouse_up(), x: 300, y: 336, button: 1, key: 0, width: 1180, height: 760, timestamp_ms: 3, text_len: 0)
    let dry_run_status: Int = ControlCenterSurface.event(app, toggle_dry_run)
    let refresh: surface.Event = surface.Event(kind: surface.event_mouse_up(), x: 480, y: 336, button: 1, key: 0, width: 1180, height: 760, timestamp_ms: 4, text_len: 0)
    let refresh_status: Int = ControlCenterSurface.event(app, refresh)
    let open_command: surface.Event = surface.Event(kind: surface.event_mouse_up(), x: 680, y: 336, button: 1, key: 0, width: 1180, height: 760, timestamp_ms: 5, text_len: 0)
    let command_status: Int = ControlCenterSurface.event(app, open_command)
    let edit_settings: surface.Event = surface.Event(kind: surface.event_mouse_up(), x: 300, y: 400, button: 1, key: 0, width: 1180, height: 760, timestamp_ms: 6, text_len: 0)
    let settings_status: Int = ControlCenterSurface.event(app, edit_settings)
    let select_log: surface.Event = surface.Event(kind: surface.event_mouse_up(), x: 320, y: 452, button: 1, key: 0, width: 1180, height: 760, timestamp_ms: 7, text_len: 0)
    let log_status: Int = ControlCenterSurface.event(app, select_log)
    let retry_error: surface.Event = surface.Event(kind: surface.event_mouse_up(), x: 680, y: 452, button: 1, key: 0, width: 1180, height: 760, timestamp_ms: 8, text_len: 0)
    let error_status: Int = ControlCenterSurface.event(app, retry_error)
    let open_blocked_dialog: surface.Event = surface.Event(kind: surface.event_mouse_up(), x: 840, y: 336, button: 1, key: 0, width: 1180, height: 760, timestamp_ms: 9, text_len: 0)
    let blocked_dialog_status: Int = ControlCenterSurface.event(app, open_blocked_dialog)
    let a: Int = app.activeScreen
    let p: Int = app.selectedProfile
    let d: Bool = app.dryRunEnabled
    let rc: Int = app.refreshCount
    let co: Bool = app.commandPaletteOpen
    let se: Int = app.settingsEditCount
    let sl: Int = app.selectedLog
    let er: Int = app.errorRetryCount
    let bd: Bool = app.blockedDialogOpen
    let e: FlagshipRecipeEvidence = build_flagship_recipe_evidence(a, p, d, rc, co, se, sl, er, bd)
    let recipe_status: Int = flagship_recipe_ready(e)
    if recipe_status != 0:
        return 2
    var before_frame: surface.Frame = surface.begin_frame(win)
    var before_ctx: draw.DrawContext = draw.DrawContext(frame: before_frame)
    let before_draw: Int = ControlCenterSurface.draw(app, before_ctx)
    let first_presented: Int = surface.present(before_ctx.frame)
    let browser_click: surface.Event = surface.poll_event(win)
    let browser_text: surface.Event = surface.poll_event(win)
    var text_bytes: []u8 = core.make_u8(4)
    let host_text_len: Int = surface.poll_event_text_len(win)
    let copied_text_len: Int = surface.poll_event_text_into(win, text_bytes)
    let browser_key: surface.Event = surface.poll_event(win)
    let browser_resize: surface.Event = surface.poll_event(win)
    let browser_click_status: Int = ControlCenterSurface.event(app, browser_click)
    if browser_resize.kind == surface.event_resize():
        win.width = browser_resize.width
        win.height = browser_resize.height
    var after_frame: surface.Frame = surface.begin_frame(win)
    var after_ctx: draw.DrawContext = draw.DrawContext(frame: after_frame)
    let after_draw: Int = ControlCenterSurface.draw(app, after_ctx)
    let second_presented: Int = surface.present(after_ctx.frame)
    let closed: Int = surface.close(win)
    let profile_flow: Int = profiles_status + performance_status + dry_run_status
    let action_flow: Int = refresh_status + command_status + settings_status + log_status
    let error_flow: Int = error_status + blocked_dialog_status + before_draw + first_presented
    let browser_flow: Int = browser_click_status + after_draw + second_presented + closed
    let flow_status: Int = profile_flow + action_flow + error_flow + browser_flow
    let text_ok: Bool = host_text_len >= copied_text_len
    let event_ok: Bool = browser_text.kind >= 0 && browser_key.kind >= 0
    if flow_status > 0 && text_ok && event_ok:
        return 5
    return 3
