// Experimental memory helpers built on top of cap.mem primitives.
//
// Promotion note: v1 stable callers should use lib.core.memory directly.
module lib.experimental.memory

import lib.core.memory as stable_memory

func memset_u8(dst: ptr, v: u8, n: i32, mem: cap.mem) -> i32
uses mem:
    return stable_memory.memset_u8(dst, v, n, mem)

func memcpy_u8(dst: ptr, src: ptr, n: i32, mem: cap.mem) -> i32
uses mem:
    return stable_memory.memcpy_u8(dst, src, n, mem)
