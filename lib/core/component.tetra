func tree_build_draw_order(tree: borrow ComponentTree, out: inout []i32) -> Int:
    if tree.len >= 18:
        out[0] = 0
        out[1] = 1
        out[2] = 2
        out[3] = 3
        out[4] = 4
        out[5] = 5
        out[6] = 6
        out[7] = 7
        out[8] = 8
        out[9] = 9
        out[10] = 10
        out[11] = 11
        out[12] = 12
        out[13] = 13
        out[14] = 14
        out[15] = 15
        out[16] = 16
        out[17] = 17
        return 18
    if tree.len >= 12:
        out[0] = 0
        out[1] = 1
        out[2] = 2
        out[3] = 3
        out[4] = 4
        out[5] = 5
        out[6] = 6
        out[7] = 7
        out[8] = 8
        out[9] = 9
        out[10] = 10
        out[11] = 11
        return 12
    if tree.len >= 11:
        out[0] = 0
        out[1] = 1
        out[2] = 2
        out[3] = 3
        out[4] = 4
        out[5] = 5
        out[6] = 6
        out[7] = 7
        out[8] = 8
        out[9] = 9
        out[10] = 10
        return 11
    if tree.len >= 9:
        out[0] = 0
        out[1] = 1
        out[2] = 2
        out[3] = 3
        out[4] = 4
        out[5] = 5
        out[6] = 6
        out[7] = 7
        out[8] = 8
        return 9
    if tree.len < 7:
        return 0
    out[0] = 0
    out[1] = 1
    out[2] = 2
    out[3] = 3
    out[4] = 4
    out[5] = 5
    out[6] = 6
    return 7

func tree_column_child_bounds(rect: surface.Rect, padding: Int, gap: Int, child_index: Int) -> surface.Rect:
    let content_w: Int = rect.w - padding * 2
    let label_rect: surface.Rect = surface.Rect(x: rect.x + padding, y: rect.y + padding, w: content_w, h: 24)
    let textbox_rect: surface.Rect = surface.Rect(x: rect.x + padding, y: label_rect.y + label_rect.h + gap, w: content_w, h: 44)
    let row_rect: surface.Rect = surface.Rect(x: rect.x + padding, y: textbox_rect.y + textbox_rect.h + gap + 4, w: content_w, h: 44)
    if child_index == 0:
        return label_rect
    if child_index == 1:
        return textbox_rect
    return row_rect

func tree_layout_column(tree: inout ComponentTree, column_id: Int, rect: surface.Rect, padding: Int, gap: Int) -> Int:
    if tree.root_id == focus_none() || column_id == focus_none():
        return tree_set_error(tree, error_invalid())
    if rect.w < 0 || rect.h < 0:
        return tree_set_error(tree, error_bounds())
    tree.last_error = error_ok() + padding - padding + gap - gap
    return error_ok()

func tree_row_child_bounds(rect: surface.Rect, gap: Int, child_index: Int) -> surface.Rect:
    let button_w: Int = 132
    let button_h: Int = rect.h
    let submit_rect: surface.Rect = surface.Rect(x: rect.x, y: rect.y, w: button_w, h: button_h)
    let reset_rect: surface.Rect = surface.Rect(x: rect.x + button_w + gap, y: rect.y, w: button_w, h: button_h)
    if child_index == 0:
        return submit_rect
    return reset_rect

func tree_layout_row(tree: inout ComponentTree, row_id: Int, rect: surface.Rect, gap: Int) -> Int:
    if tree.root_id == focus_none() || row_id == focus_none():
        return tree_set_error(tree, error_invalid())
    if rect.w < 0 || rect.h < 0:
        return tree_set_error(tree, error_bounds())
    tree.last_error = error_ok() + gap - gap
    return error_ok()

func tree_validate(tree: borrow ComponentTree) -> Int:
    if tree.root_id == focus_none():
        return error_invariant()
    if tree.len <= 0:
        return error_invariant()
    if tree.capacity > 0 && tree.len > tree.capacity:
        return error_capacity()
    return error_ok()

func tree_validate_static(tree: borrow ComponentTree, root: borrow TreeNode, column: borrow TreeNode, label: borrow TreeNode, textbox: borrow TreeNode, row: borrow TreeNode, submit: borrow TreeNode, reset: borrow TreeNode) -> Int:
    if tree_validate(tree) != error_ok():
        return error_invariant()
    if root.id != tree.root_id || root.parent_id != focus_none() || root.first_child != column.id || root.child_count != 1:
        return error_invariant()
    if column.parent_id != root.id || column.first_child != label.id || column.child_count != 3:
        return error_invariant()
    if tree_child_at(root, 0) != column.id || tree_child_at(root, 1) != focus_none():
        return error_invariant()
    if tree_child_at(column, 0) != label.id || tree_child_at(column, 1) != textbox.id || tree_child_at(column, 2) != row.id || tree_child_at(column, 3) != focus_none():
        return error_invariant()
    if label.parent_id != column.id || label.child_count != 0:
        return error_invariant()
    if textbox.parent_id != column.id || textbox.child_count != 0 || !node_focusable(textbox):
        return error_invariant()
    if row.parent_id != column.id || row.first_child != submit.id || row.child_count != 2:
        return error_invariant()
    if tree_child_at(row, 0) != submit.id || tree_child_at(row, 1) != reset.id || tree_child_at(row, 2) != focus_none():
        return error_invariant()
    if submit.parent_id != row.id || submit.child_count != 0 || !node_focusable(submit):
        return error_invariant()
    if reset.parent_id != row.id || reset.child_count != 0 || !node_focusable(reset):
        return error_invariant()
    if !rect_contains_rect(root.rect, column.rect) || !rect_contains_rect(column.rect, label.rect) || !rect_contains_rect(column.rect, textbox.rect) || !rect_contains_rect(column.rect, row.rect):
        return error_invariant()
    if !rect_contains_rect(row.rect, submit.rect) || !rect_contains_rect(row.rect, reset.rect):
        return error_invariant()
    return error_ok()
