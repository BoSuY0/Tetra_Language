func paint_feature_radius() -> Int:
    return 4

func paint_feature_shadow() -> Int:
    return 8

func paint_feature_outline() -> Int:
    return 16

func paint_feature_gradient() -> Int:
    return 32

func paint_feature_overlay() -> Int:
    return 64

func paint_feature_unsupported_blur() -> Int:
    return 128

