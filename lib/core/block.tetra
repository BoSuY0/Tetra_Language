// Experimental Surface Block System core data model.
// Effects: alloc, mem
// ```tetra doctest
// func block_doctest() -> Int:
//     let rect: lib.core.surface.Rect = lib.core.surface.Rect(x: 0, y: 0, w: 100, h: 40)
//     let id: lib.core.block.BlockID = lib.core.block.id(1)
//     let props: lib.core.block.BlockProps = lib.core.block.props_default(rect)
//     let root: lib.core.block.Block = lib.core.block.make(id, lib.core.block.id_none(), props)
//     return lib.core.block.id_value(root.id)
// ```
module lib.core.block

import lib.core.surface as surface

struct BlockID:
    value: Int

struct AssetRef:
    kind: Int
    index: Int
    width: Int
    height: Int
    hash: Int

struct AssetManifest:
    font_hash: Int
    icon_hash: Int
    image_hash: Int
    font_count: Int
    icon_count: Int
    image_count: Int
    budget_bytes: Int
    max_entries: Int
    local_only: Bool
    remote_count: Int

struct LayoutSpec:
    mode: Int
    x: Int
    y: Int
    w: Int
    h: Int
    min_w: Int
    min_h: Int
    max_w: Int
    max_h: Int
    flags: Int

struct PaintLayer:
    kind: Int
    r: Int
    g: Int
    b: Int
    a: Int
    radius: Int
    width: Int
    blur: Int
    offset_x: Int
    offset_y: Int

struct PaintSpec:
    layer_count: Int
    layer0_kind: Int
    layer1_kind: Int
    layer2_kind: Int
    layer3_kind: Int
    checksum: Int

struct TextSpec:
    text_len: Int
    r: Int
    g: Int
    b: Int
    a: Int
    font_size: Int
    font_weight: Int
    line_height: Int
    flags: Int
    placeholder_len: Int

struct ImageSpec:
    asset_kind: Int
    asset_index: Int
    width: Int
    height: Int
    fit: Int
    opacity: Int
    tint_r: Int
    tint_g: Int
    tint_b: Int
    tint_a: Int

struct InputSpec:
    accepts_pointer: Bool
    accepts_keyboard: Bool
    accepts_text: Bool
    focusable: Bool
    disabled: Bool
    cursor: Int

struct EventSpec:
    click_action: Int
    pointer_action: Int
    key_action: Int
    text_action: Int
    submit_action: Int

struct StateSelector:
    hovered: Bool
    pressed: Bool
    focused: Bool
    selected: Bool
    disabled: Bool
    error: Bool
    loading: Bool

struct StateSpec:
    selector_flags: Int
    variant: Int
    selected: Bool
    disabled: Bool
    error: Bool
    loading: Bool

struct MotionSpec:
    duration_ms: Int
    delay_ms: Int
    easing: Int
    reduced: Bool
    animate_opacity: Bool
    animate_color: Bool
    animate_transform: Bool
    translate_x: Int
    translate_y: Int
    scale: Int

struct AccessibilitySpec:
    role: Int
    label_len: Int
    labelled_by: BlockID
    described_by: BlockID
    focus_order: Int
    reading_order: Int
    actions: Int
    hidden: Bool

// Compact enough to keep Block returns inside the current 10-slot ABI limit.
struct BlockProps:
    layout_mode: Int
    paint_layers: Int
    text_len: Int
    visual_asset: Int
    interaction_flags: Int
    state_flags: Int
    motion_ms: Int
    accessibility_role: Int

struct Block:
    id: BlockID
    parent_id: BlockID
    props: BlockProps

struct BlockTree:
    storage: []i32
    len: Int
    capacity: Int
    root_id: Int
    last_error: Int

struct BlockGraph:
    tree: BlockTree
    schema_version: Int

func id(value: Int) -> BlockID:
    return BlockID(value: value)

func id_none() -> BlockID:
    return BlockID(value: -1)

func id_value(block_id: BlockID) -> Int:
    return block_id.value

func asset_kind_none() -> Int:
    return 0

func asset_kind_font() -> Int:
    return 1

func asset_kind_image() -> Int:
    return 2

func asset_kind_icon() -> Int:
    return 3

func asset_quality_level() -> Int:
    return 1

func asset_error_ok() -> Int:
    return 0

func asset_error_unbounded_cache() -> Int:
    return 1

func asset_error_over_budget() -> Int:
    return 2

func asset_error_too_many_entries() -> Int:
    return 3

func asset_error_missing_fallback() -> Int:
    return 4

func asset_error_network_rejected() -> Int:
    return 5

func asset_none() -> AssetRef:
    return AssetRef(kind: asset_kind_none(), index: -1, width: 0, height: 0, hash: 0)

func asset_embedded(kind: Int, index: Int, width: Int, height: Int, hash: Int) -> AssetRef:
    return AssetRef(kind: kind, index: index, width: width, height: height, hash: hash)

func asset_font(index: Int, hash: Int) -> AssetRef:
    return asset_embedded(asset_kind_font(), index, 0, 0, hash)

func asset_icon(index: Int, width: Int, height: Int, hash: Int) -> AssetRef:
    return asset_embedded(asset_kind_icon(), index, width, height, hash)

func asset_image(index: Int, width: Int, height: Int, hash: Int) -> AssetRef:
    return asset_embedded(asset_kind_image(), index, width, height, hash)

func asset_missing(kind: Int, index: Int) -> AssetRef:
    return AssetRef(kind: kind, index: index, width: 0, height: 0, hash: -1)

func asset_remote_url(kind: Int, index: Int) -> AssetRef:
    return AssetRef(kind: kind, index: index, width: 0, height: 0, hash: -2)

func asset_kind(asset: AssetRef) -> Int:
    return asset.kind

func asset_hash(asset: AssetRef) -> Int:
    return asset.hash

func asset_width(asset: AssetRef) -> Int:
    return asset.width

func asset_height(asset: AssetRef) -> Int:
    return asset.height

func asset_is_embedded(asset: AssetRef) -> Bool:
    return asset.hash > 0 && asset.index >= 0

func asset_is_local(asset: AssetRef) -> Bool:
    return asset.hash > 0

func asset_is_remote_url(asset: AssetRef) -> Bool:
    return asset.hash == -2

func asset_resolve_status(asset: AssetRef) -> Int:
    if asset.hash == -2:
        return asset_error_network_rejected()
    if asset.hash < 0:
        return asset_error_missing_fallback()
    return asset_error_ok()

func asset_cache_budget_bytes() -> Int:
    return 65536

func asset_cache_entry_limit() -> Int:
    return 16

func asset_cache_validate(budget_bytes: Int, used_bytes: Int, entry_count: Int, repeated_loads: Int) -> Int:
    if budget_bytes <= 0 || budget_bytes > asset_cache_budget_bytes():
        return asset_error_unbounded_cache()
    if used_bytes < 0 || used_bytes > budget_bytes:
        return asset_error_over_budget()
    if entry_count < 0 || entry_count > asset_cache_entry_limit():
        return asset_error_too_many_entries()
    if repeated_loads < entry_count:
        return asset_error_unbounded_cache()
    return asset_error_ok()

func asset_manifest(font: AssetRef, icon: AssetRef, image: AssetRef, budget_bytes: Int, max_entries: Int) -> AssetManifest:
    var local_only: Bool = true
    if !asset_is_local(font):
        local_only = false
    if !asset_is_local(icon):
        local_only = false
    if !asset_is_local(image):
        local_only = false
    return AssetManifest(font_hash: font.hash, icon_hash: icon.hash, image_hash: image.hash, font_count: 1, icon_count: 1, image_count: 1, budget_bytes: budget_bytes, max_entries: max_entries, local_only: local_only, remote_count: 0)

func asset_manifest_hash(manifest: AssetManifest) -> Int:
    return manifest.font_hash + manifest.icon_hash + manifest.image_hash + manifest.font_count + manifest.icon_count + manifest.image_count

func asset_manifest_validate(manifest: AssetManifest) -> Int:
    if !manifest.local_only || manifest.remote_count != 0:
        return asset_error_network_rejected()
    if manifest.font_count <= 0 || manifest.icon_count <= 0 || manifest.image_count <= 0:
        return asset_error_missing_fallback()
    if manifest.font_hash <= 0 || manifest.icon_hash <= 0 || manifest.image_hash <= 0:
        return asset_error_missing_fallback()
    return asset_cache_validate(manifest.budget_bytes, manifest.font_count + manifest.icon_count + manifest.image_count, manifest.font_count + manifest.icon_count + manifest.image_count, manifest.font_count + manifest.icon_count + manifest.image_count)

func asset_diagnostic_missing_asset() -> Int:
    return 1

func asset_diagnostic_network_rejected() -> Int:
    return 2

func layout_mode_fixed() -> Int:
    return 1

func layout_mode_stack() -> Int:
    return 2

func layout_mode_row() -> Int:
    return 3

func layout_mode_column() -> Int:
    return 4

func layout_mode_overlay() -> Int:
    return 5

func layout_mode_absolute() -> Int:
    return 6

func layout_mode_grid() -> Int:
    return 7

func layout_mode_dock() -> Int:
    return 8

func layout_mode_scroll() -> Int:
    return 9

func layout_size_fixed() -> Int:
    return 1

func layout_size_fit() -> Int:
    return 2

func layout_size_fill() -> Int:
    return 3

func layout_align_start() -> Int:
    return 1

func layout_align_center() -> Int:
    return 2

func layout_align_end() -> Int:
    return 3

func layout_align_stretch() -> Int:
    return 4

func layout_justify_start() -> Int:
    return 1

func layout_justify_center() -> Int:
    return 2

func layout_justify_end() -> Int:
    return 3

func layout_justify_space_between() -> Int:
    return 4

func layout_overflow_visible() -> Int:
    return 1

func layout_overflow_clip() -> Int:
    return 2

func layout_overflow_scroll() -> Int:
    return 3

func layout_dock_left() -> Int:
    return 1

func layout_dock_right() -> Int:
    return 2

func layout_dock_top() -> Int:
    return 3

func layout_dock_bottom() -> Int:
    return 4

func layout_dock_fill() -> Int:
    return 5

func layout_density_dpi_default() -> Int:
    return 96

func layout_density_scale_default() -> Int:
    return 1000

func layout_density_scale_retina() -> Int:
    return 2000

func layout_error_ok() -> Int:
    return 0

func layout_error_invalid() -> Int:
    return 1

func layout_error_bounds() -> Int:
    return 2

func layout_clamp_small(value: Int, min_value: Int, max_value: Int) -> Int:
    if value < min_value:
        return min_value
    if value > max_value:
        return max_value
    return value

func layout_stable_round_div(value: Int, divisor: Int) -> Int:
    if divisor <= 0:
        return 0
    if value <= 0:
        return 0
    return (value + divisor / 2) / divisor

func layout_scale_px(value: Int, scale_milli: Int) -> Int:
    let safe_scale: Int = layout_clamp_small(scale_milli, 250, 4000)
    return layout_stable_round_div(value * safe_scale, 1000)

func layout_pack_flags(padding: Int, gap: Int, align: Int, justify: Int, overflow: Int, z_index: Int, width_policy: Int, height_policy: Int) -> Int:
    let safe_padding: Int = layout_clamp_small(padding, 0, 99)
    let safe_gap: Int = layout_clamp_small(gap, 0, 99)
    let safe_align: Int = layout_clamp_small(align, layout_align_start(), layout_align_stretch())
    let safe_justify: Int = layout_clamp_small(justify, layout_justify_start(), layout_justify_space_between())
    let safe_overflow: Int = layout_clamp_small(overflow, layout_overflow_visible(), layout_overflow_scroll())
    let safe_z: Int = layout_clamp_small(z_index, 0, 9)
    let safe_width_policy: Int = layout_clamp_small(width_policy, layout_size_fixed(), layout_size_fill())
    let safe_height_policy: Int = layout_clamp_small(height_policy, layout_size_fixed(), layout_size_fill())
    return safe_padding + safe_gap * 100 + safe_align * 10000 + safe_justify * 100000 + safe_overflow * 1000000 + safe_z * 10000000 + safe_width_policy * 100000000 + safe_height_policy * 400000000

func layout_padding(spec: LayoutSpec) -> Int:
    return spec.flags % 100

func layout_gap(spec: LayoutSpec) -> Int:
    return spec.flags / 100 % 100

func layout_align_value(spec: LayoutSpec) -> Int:
    let value: Int = spec.flags / 10000 % 10
    if value <= 0:
        return layout_align_start()
    return value

func layout_justify_value(spec: LayoutSpec) -> Int:
    let value: Int = spec.flags / 100000 % 10
    if value <= 0:
        return layout_justify_start()
    return value

func layout_overflow_value(spec: LayoutSpec) -> Int:
    let value: Int = spec.flags / 1000000 % 10
    if value <= 0:
        return layout_overflow_visible()
    return value

func layout_z_index(spec: LayoutSpec) -> Int:
    return spec.flags / 10000000 % 10

func layout_width_policy(spec: LayoutSpec) -> Int:
    let value: Int = spec.flags / 100000000 % 4
    if value <= 0:
        return layout_size_fixed()
    return value

func layout_height_policy(spec: LayoutSpec) -> Int:
    let value: Int = spec.flags / 400000000 % 4
    if value <= 0:
        return layout_size_fixed()
    return value

func layout_base(mode: Int, rect: surface.Rect) -> LayoutSpec:
    return LayoutSpec(mode: mode, x: rect.x, y: rect.y, w: rect.w, h: rect.h, min_w: 0, min_h: 0, max_w: rect.w, max_h: rect.h, flags: 0)

func layout_constrained(mode: Int, rect: surface.Rect, width_policy: Int, height_policy: Int, min_w: Int, min_h: Int, max_w: Int, max_h: Int, padding: Int, gap: Int, align: Int, justify: Int, overflow: Int, z_index: Int) -> LayoutSpec:
    var safe_max_w: Int = max_w
    var safe_max_h: Int = max_h
    if safe_max_w <= 0:
        safe_max_w = rect.w
    if safe_max_h <= 0:
        safe_max_h = rect.h
    return LayoutSpec(mode: mode, x: rect.x, y: rect.y, w: rect.w, h: rect.h, min_w: min_w, min_h: min_h, max_w: safe_max_w, max_h: safe_max_h, flags: layout_pack_flags(padding, gap, align, justify, overflow, z_index, width_policy, height_policy))

func layout_fixed(rect: surface.Rect) -> LayoutSpec:
    return layout_constrained(layout_mode_fixed(), rect, layout_size_fixed(), layout_size_fixed(), rect.w, rect.h, rect.w, rect.h, 0, 0, layout_align_start(), layout_justify_start(), layout_overflow_visible(), 0)

func layout_stack(rect: surface.Rect, gap: Int) -> LayoutSpec:
    return layout_constrained(layout_mode_stack(), rect, layout_size_fixed(), layout_size_fixed(), 0, 0, rect.w, rect.h, 0, gap, layout_align_start(), layout_justify_start(), layout_overflow_visible(), 0)

func layout_row(rect: surface.Rect, gap: Int) -> LayoutSpec:
    return layout_constrained(layout_mode_row(), rect, layout_size_fixed(), layout_size_fixed(), 0, 0, rect.w, rect.h, 0, gap, layout_align_center(), layout_justify_start(), layout_overflow_visible(), 0)

func layout_column(rect: surface.Rect, gap: Int) -> LayoutSpec:
    return layout_constrained(layout_mode_column(), rect, layout_size_fixed(), layout_size_fixed(), 0, 0, rect.w, rect.h, 0, gap, layout_align_stretch(), layout_justify_start(), layout_overflow_visible(), 0)

func layout_absolute(rect: surface.Rect, z_index: Int) -> LayoutSpec:
    return layout_constrained(layout_mode_absolute(), rect, layout_size_fixed(), layout_size_fixed(), rect.w, rect.h, rect.w, rect.h, 0, 0, layout_align_start(), layout_justify_start(), layout_overflow_visible(), z_index)

func layout_overlay(rect: surface.Rect, z_index: Int) -> LayoutSpec:
    return layout_constrained(layout_mode_overlay(), rect, layout_size_fixed(), layout_size_fixed(), rect.w, rect.h, rect.w, rect.h, 0, 0, layout_align_end(), layout_justify_start(), layout_overflow_visible(), z_index)

func layout_grid(rect: surface.Rect, columns: Int, rows: Int, gap: Int) -> LayoutSpec:
    let safe_columns: Int = layout_clamp_small(columns, 1, 12)
    let safe_rows: Int = layout_clamp_small(rows, 1, 12)
    return layout_constrained(layout_mode_grid(), rect, layout_size_fill(), layout_size_fill(), safe_columns, safe_rows, rect.w, rect.h, 0, gap, layout_align_stretch(), layout_justify_start(), layout_overflow_clip(), 0)

func layout_dock(rect: surface.Rect, edge: Int, size: Int) -> LayoutSpec:
    let safe_edge: Int = layout_clamp_small(edge, layout_dock_left(), layout_dock_fill())
    let safe_size: Int = layout_clamp_small(size, 0, 4096)
    return layout_constrained(layout_mode_dock(), rect, layout_size_fixed(), layout_size_fixed(), safe_edge, safe_size, rect.w, rect.h, 0, 0, layout_align_stretch(), layout_justify_start(), layout_overflow_clip(), 0)

func layout_scroll(rect: surface.Rect, content_w: Int, content_h: Int, offset_y: Int) -> LayoutSpec:
    let safe_content_w: Int = layout_clamp_small(content_w, rect.w, 16384)
    let safe_content_h: Int = layout_clamp_small(content_h, rect.h, 16384)
    let safe_offset_y: Int = layout_clamp_small(offset_y, 0, safe_content_h)
    return LayoutSpec(mode: layout_mode_scroll(), x: rect.x, y: rect.y, w: rect.w, h: rect.h, min_w: safe_content_w, min_h: safe_content_h, max_w: rect.w, max_h: safe_offset_y, flags: layout_pack_flags(0, 0, layout_align_start(), layout_justify_start(), layout_overflow_scroll(), 0, layout_size_fixed(), layout_size_fixed()))

func layout_rect(spec: LayoutSpec) -> surface.Rect:
    return surface.Rect(x: spec.x, y: spec.y, w: spec.w, h: spec.h)

func layout_resize(spec: LayoutSpec, width: Int, height: Int) -> LayoutSpec:
    var next: LayoutSpec = spec
    next.w = width
    next.h = height
    return next

func layout_resize_density(spec: LayoutSpec, width: Int, height: Int, scale_milli: Int) -> LayoutSpec:
    return layout_resize(spec, layout_scale_px(width, scale_milli), layout_scale_px(height, scale_milli))

func layout_aspect_fit(rect: surface.Rect, aspect_w: Int, aspect_h: Int) -> LayoutSpec:
    let safe_aspect_w: Int = layout_clamp_small(aspect_w, 1, 1000)
    let safe_aspect_h: Int = layout_clamp_small(aspect_h, 1, 1000)
    var out_w: Int = rect.w
    var out_h: Int = layout_stable_round_div(rect.w * safe_aspect_h, safe_aspect_w)
    if out_h > rect.h:
        out_h = rect.h
        out_w = layout_stable_round_div(rect.h * safe_aspect_w, safe_aspect_h)
    let out_rect: surface.Rect = surface.Rect(x: rect.x, y: rect.y, w: out_w, h: out_h)
    return layout_constrained(layout_mode_fixed(), out_rect, layout_size_fixed(), layout_size_fixed(), out_w, out_h, out_w, out_h, 0, 0, layout_align_start(), layout_justify_start(), layout_overflow_clip(), 0)

func layout_clamp_dimension(value: Int, min_value: Int, max_value: Int) -> Int:
    var out: Int = value
    if min_value > 0 && out < min_value:
        out = min_value
    if max_value > 0 && out > max_value:
        out = max_value
    if out < 0:
        return 0
    return out

func layout_effective_width(spec: LayoutSpec, measured: surface.Size, available: Int) -> Int:
    var width: Int = spec.w
    if layout_width_policy(spec) == layout_size_fit():
        width = measured.w + layout_padding(spec) * 2
    if layout_width_policy(spec) == layout_size_fill():
        width = available
    if width <= 0:
        width = measured.w
    return layout_clamp_dimension(width, spec.min_w, spec.max_w)

func layout_effective_height(spec: LayoutSpec, measured: surface.Size, available: Int) -> Int:
    var height: Int = spec.h
    if layout_height_policy(spec) == layout_size_fit():
        height = measured.h + layout_padding(spec) * 2
    if layout_height_policy(spec) == layout_size_fill():
        height = available
    if height <= 0:
        height = measured.h
    return layout_clamp_dimension(height, spec.min_h, spec.max_h)

func layout_grid_columns(spec: LayoutSpec) -> Int:
    return layout_clamp_small(spec.min_w, 1, 12)

func layout_grid_rows(spec: LayoutSpec) -> Int:
    return layout_clamp_small(spec.min_h, 1, 12)

func layout_scroll_max_offset(spec: LayoutSpec) -> Int:
    if spec.mode != layout_mode_scroll():
        return 0
    let max_offset: Int = spec.min_h - spec.h
    if max_offset < 0:
        return 0
    return max_offset

func layout_scroll_offset_y(spec: LayoutSpec) -> Int:
    return layout_clamp_small(spec.max_h, 0, layout_scroll_max_offset(spec))

func layout_validate_constraints(spec: LayoutSpec) -> Int:
    if spec.mode < layout_mode_fixed() || spec.mode > layout_mode_scroll():
        return layout_error_invalid()
    if spec.w < 0 || spec.h < 0 || spec.min_w < 0 || spec.min_h < 0 || spec.max_w < 0 || spec.max_h < 0:
        return layout_error_bounds()
    if spec.max_w > 0 && spec.min_w > spec.max_w && spec.mode != layout_mode_grid() && spec.mode != layout_mode_dock() && spec.mode != layout_mode_scroll():
        return layout_error_bounds()
    if spec.max_h > 0 && spec.min_h > spec.max_h && spec.mode != layout_mode_grid() && spec.mode != layout_mode_dock() && spec.mode != layout_mode_scroll():
        return layout_error_bounds()
    return layout_error_ok()

func layout_resolve_child(parent: LayoutSpec, child: LayoutSpec, index: Int, child_count: Int, measured: surface.Size) -> surface.Rect:
    let parent_padding: Int = layout_padding(parent)
    let parent_gap: Int = layout_gap(parent)
    var safe_count: Int = child_count
    if safe_count < 1:
        safe_count = 1
    let available_w: Int = layout_clamp_dimension(parent.w - parent_padding * 2 - parent_gap * (safe_count - 1), 0, parent.w)
    let available_h: Int = layout_clamp_dimension(parent.h - parent_padding * 2 - parent_gap * (safe_count - 1), 0, parent.h)
    var width: Int = layout_effective_width(child, measured, available_w)
    var height: Int = layout_effective_height(child, measured, available_h)
    var x: Int = parent.x + parent_padding + child.x
    var y: Int = parent.y + parent_padding + child.y
    if parent.mode == layout_mode_row():
        if layout_width_policy(child) == layout_size_fill():
            width = layout_stable_round_div(available_w, safe_count)
        x = parent.x + parent_padding + index * (width + parent_gap)
        y = parent.y + parent_padding
        if layout_align_value(parent) == layout_align_center():
            y = parent.y + parent_padding + (parent.h - parent_padding * 2 - height) / 2
    if parent.mode == layout_mode_column() || parent.mode == layout_mode_stack():
        if layout_width_policy(child) == layout_size_fill():
            width = parent.w - parent_padding * 2
        y = parent.y + parent_padding + index * (height + parent_gap)
        x = parent.x + parent_padding
        if layout_align_value(parent) == layout_align_center():
            x = parent.x + parent_padding + (parent.w - parent_padding * 2 - width) / 2
        if layout_align_value(parent) == layout_align_end():
            x = parent.x + parent.w - parent_padding - width
        if layout_align_value(parent) == layout_align_stretch():
            width = parent.w - parent_padding * 2
    if child.mode == layout_mode_absolute():
        x = parent.x + child.x
        y = parent.y + child.y
    if child.mode == layout_mode_overlay():
        x = child.x
        y = child.y
    if child.mode == layout_mode_grid():
        let columns: Int = layout_grid_columns(child)
        let rows: Int = layout_grid_rows(child)
        let gap: Int = layout_gap(child)
        let col: Int = index % columns
        let row: Int = index / columns
        width = layout_stable_round_div(child.w - gap * (columns - 1), columns)
        height = layout_stable_round_div(child.h - gap * (rows - 1), rows)
        x = child.x + col * (width + gap)
        y = child.y + row * (height + gap)
    if child.mode == layout_mode_dock():
        let edge: Int = child.min_w
        let size: Int = child.min_h
        x = child.x
        y = child.y
        width = child.w
        height = child.h
        if edge == layout_dock_top():
            height = size
        if edge == layout_dock_bottom():
            y = child.y + child.h - size
            height = size
        if edge == layout_dock_left():
            width = size
        if edge == layout_dock_right():
            x = child.x + child.w - size
            width = size
        if edge == layout_dock_fill():
            width = child.w
            height = child.h
    if child.mode == layout_mode_scroll():
        x = child.x
        y = child.y
        width = child.w
        height = child.h
    return surface.Rect(x: x, y: y, w: width, h: height)

func paint_layer_kind_none() -> Int:
    return 0

