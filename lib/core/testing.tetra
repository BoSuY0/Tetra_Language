// Stable v1 core testing helpers promoted from lib.experimental.testing.
// Effects: none
// ```tetra doctest
// func testing_doctest() -> Int:
//     return lib.core.testing.assert_eq_i32(42, 42)
// ```
module lib.core.testing

func assert_true(value: Bool) -> Int:
    if value:
        return 0
    return 1

func assert_false(value: Bool) -> Int:
    if value:
        return 1
    return 0

func assert_eq_i32(actual: Int, expected: Int) -> Int:
    if actual == expected:
        return 0
    return 1

func combine(lhs: Int, rhs: Int) -> Int:
    if lhs != 0:
        return lhs
    return rhs
