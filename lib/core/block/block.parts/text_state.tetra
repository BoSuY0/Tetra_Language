func image_asset_tinted_scaled(asset: AssetRef, width: Int, height: Int, tint: surface.Color, scale: Int) -> ImageSpec:
    return ImageSpec(
        asset_kind: asset.kind,
        asset_index: asset.index,
        width: width,
        height: height,
        fit: scale,
        opacity: tint.a,
        tint_r: tint.r,
        tint_g: tint.g,
        tint_b: tint.b,
        tint_a: tint.a,
    )

