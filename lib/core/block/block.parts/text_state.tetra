        hidden: false,
    )

func accessibility_button_labelled_by(label_len: Int, label_id: BlockID, action: Int) -> AccessibilitySpec:
    return AccessibilitySpec(
        role: accessibility_role_button(),
        label_len: label_len,
        labelled_by: label_id,
        described_by: id_none(),
        focus_order: 0,
        reading_order: 0,
        actions: action,
        hidden: false,
    )

func accessibility_textbox_labelled_by(label_len: Int, label_id: BlockID) -> AccessibilitySpec:
    return AccessibilitySpec(
        role: accessibility_role_textbox(),
        label_len: label_len,
        labelled_by: label_id,
        described_by: id_none(),
        focus_order: 0,
        reading_order: 0,
        actions: action_primary(),
        hidden: false,
    )

func accessibility_checkbox(label_len: Int) -> AccessibilitySpec:
    return AccessibilitySpec(
        role: accessibility_role_checkbox(),
        label_len: label_len,
        labelled_by: id_none(),
        described_by: id_none(),
        focus_order: 0,
        reading_order: 0,
        actions: action_primary(),
        hidden: false,
    )

func accessibility_navigation(label_len: Int) -> AccessibilitySpec:
    return AccessibilitySpec(
        role: accessibility_role_navigation(),
        label_len: label_len,
        labelled_by: id_none(),
        described_by: id_none(),
        focus_order: -1,
        reading_order: 0,
        actions: 0,
        hidden: false,
    )

func accessibility_region(label_len: Int) -> AccessibilitySpec:
    return AccessibilitySpec(
        role: accessibility_role_region(),
        label_len: label_len,
        labelled_by: id_none(),
        described_by: id_none(),
        focus_order: -1,
        reading_order: 0,
        actions: 0,
        hidden: false,
    )

func accessibility_dialog(label_len: Int) -> AccessibilitySpec:
    return AccessibilitySpec(
        role: accessibility_role_dialog(),
        label_len: label_len,
        labelled_by: id_none(),
        described_by: id_none(),
        focus_order: 0,
        reading_order: 0,
        actions: action_primary(),
        hidden: false,
    )

func accessibility_status(label_len: Int) -> AccessibilitySpec:
    return AccessibilitySpec(
        role: accessibility_role_status(),
        label_len: label_len,
        labelled_by: id_none(),
        described_by: id_none(),
        focus_order: -1,
        reading_order: 0,
        actions: 0,
        hidden: false,
    )

func accessibility_focusable_has_name(spec: AccessibilitySpec) -> Bool:
    let direct_focus: Bool = spec.focus_order >= 0 || spec.actions > 0
    let button: Bool = spec.role == accessibility_role_button()
    let text: Bool = spec.role == accessibility_role_textbox()
    let check: Bool = spec.role == accessibility_role_checkbox()
    let dialog: Bool = spec.role == accessibility_role_dialog()
    let focusable: Bool = direct_focus || button || text || check || dialog
    if !focusable:
        return true
    return spec.label_len > 0 || id_value(spec.labelled_by) != id_value(id_none())

func accessibility_relationship_matches(label: AccessibilitySpec, target: AccessibilitySpec, label_id: BlockID, target_id: BlockID) -> Bool:
    let describes: Bool = id_value(label.described_by) == id_value(target_id)
    let labelled: Bool = id_value(target.labelled_by) == id_value(label_id)
    let label_exists: Bool = id_value(label_id) != id_value(id_none())
    let target_exists: Bool = id_value(target_id) != id_value(id_none())
    return describes && labelled && label_exists && target_exists

func accessibility_reading_order_matches(before: Int, after: Int) -> Bool:
    return before >= 0 && after > before

func accessibility_metadata_claim_scoped(platform_host_integration: Bool, dom_aria_integration: Bool, screen_reader_evidence: Bool) -> Bool:
    return !platform_host_integration && !dom_aria_integration && !screen_reader_evidence

func accessibility_screen_reader_claim_allowed(platform_host_integration: Bool, screen_reader_evidence: Bool) -> Bool:
    if screen_reader_evidence:
        return platform_host_integration
    return true

func input_flags(input: InputSpec) -> Int:
    var flags: Int = input.cursor
    if input.accepts_pointer:
        flags = flags + 10
    if input.accepts_keyboard:
        flags = flags + 20
    if input.accepts_text:
        flags = flags + 40
    if input.focusable:
        flags = flags + 80
    if input.disabled:
        flags = flags + 160
    return flags

func props(layout: LayoutSpec, paint: PaintSpec, text: TextSpec, image: ImageSpec, input: InputSpec, event: EventSpec, state: StateSpec, motion: MotionSpec, accessibility: AccessibilitySpec, asset: AssetRef) -> BlockProps:
    let click_text: Int = event.click_action + event.text_action
    let interaction: Int = input_flags(input) + click_text + event.submit_action
    let visual_asset: Int = image.asset_index + asset.hash - asset.hash
    let state_summary: Int = state.selector_flags + state.variant
    return BlockProps(
        layout_mode: layout.mode,
        paint_layers: paint.layer_count,
        text_len: text.text_len,
        visual_asset: visual_asset,
        interaction_flags: interaction,
        state_flags: state_summary,
        motion_ms: motion.duration_ms,
        accessibility_role: accessibility.role,
    )

func props_default(rect: surface.Rect) -> BlockProps:
    let layout: LayoutSpec = layout_fixed(rect)
    let paint: PaintSpec = paint_empty()
    let text: TextSpec = text_none()
    let image: ImageSpec = image_none()
    let input: InputSpec = input_none()
    let event: EventSpec = event_none()
    let state: StateSpec = state_base()
    let motion: MotionSpec = motion_none()
    let access: AccessibilitySpec = accessibility_none()
    return props(layout, paint, text, image, input, event, state, motion, access, asset_none())

func make(id: BlockID, parent_id: BlockID, props: BlockProps) -> Block:
    return Block(id: id, parent_id: parent_id, props: props)

func with_paint(block: Block, paint: PaintSpec) -> Block:
    var next: Block = block
    next.props.paint_layers = paint.layer_count
    return next

func with_text(block: Block, text: TextSpec) -> Block:
    var next: Block = block
    next.props.text_len = text.text_len
    return next

func with_accessibility(block: Block, accessibility: AccessibilitySpec) -> Block:
    var next: Block = block
    next.props.accessibility_role = accessibility.role
    return next
