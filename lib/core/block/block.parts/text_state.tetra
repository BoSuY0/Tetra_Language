func state_selector_none() -> StateSelector:
    return StateSelector(
        hovered: false,
        pressed: false,
        focused: false,
        selected: false,
        disabled: false,
        error: false,
        loading: false,
    )

func state_selector(hovered: Bool, pressed: Bool, focused: Bool, selected: Bool, disabled: Bool, error: Bool, loading: Bool) -> StateSelector:
    return StateSelector(
        hovered: hovered,
        pressed: pressed,
        focused: focused,
        selected: selected,
        disabled: disabled,
        error: error,
        loading: loading,
    )

func state_selector_hover() -> StateSelector:
    return state_selector(true, false, false, false, false, false, false)

func state_selector_pressed() -> StateSelector:
    return state_selector(false, true, false, false, false, false, false)

func state_selector_focused() -> StateSelector:
    return state_selector(false, false, true, false, false, false, false)

func state_selector_selected() -> StateSelector:
    return state_selector(false, false, false, true, false, false, false)

func state_selector_disabled() -> StateSelector:
    return state_selector(false, false, false, false, true, false, false)

func state_selector_error() -> StateSelector:
    return state_selector(false, false, false, false, false, true, false)

func state_selector_loading() -> StateSelector:
    return state_selector(false, false, false, false, false, false, true)

func state_flags(selector: StateSelector) -> Int:
    var flags: Int = 0
    if selector.hovered:
        flags = flags + 1
    if selector.pressed:
        flags = flags + 2
    if selector.focused:
        flags = flags + 4
    if selector.selected:
        flags = flags + 8
    if selector.disabled:
        flags = flags + 16
    if selector.error:
        flags = flags + 32
    if selector.loading:
        flags = flags + 64
    return flags

func state_base() -> StateSpec:
    return StateSpec(
        selector_flags: 0,
        variant: 0,
        selected: false,
        disabled: false,
        error: false,
        loading: false,
    )

func state_interactive() -> StateSpec:
    let selector: StateSelector = state_selector_none()
    return StateSpec(
        selector_flags: state_flags(selector),
        variant: 1,
        selected: false,
        disabled: false,
        error: false,
        loading: false,
    )

func state_variant(variant: Int) -> StateSpec:
    return StateSpec(
        selector_flags: 0,
        variant: variant,
        selected: false,
        disabled: false,
        error: false,
        loading: false,
    )

func state_with_selector(selector: StateSelector, variant: Int) -> StateSpec:
    return StateSpec(
        selector_flags: state_flags(selector),
        variant: variant,
        selected: selector.selected,
        disabled: selector.disabled,
        error: selector.error,
        loading: selector.loading,
    )

func state_resolver_order_base() -> Int:
    return 1

func state_resolver_order_variant() -> Int:
    return 2

func state_resolver_order_hover() -> Int:
    return 3

func state_resolver_order_pressed() -> Int:
    return 4

func state_resolver_order_focused() -> Int:
    return 5

func state_resolver_order_selected() -> Int:
    return 6

func state_resolver_order_disabled() -> Int:
    return 7

func state_resolver_order_error() -> Int:
    return 8

func state_resolver_order_loading() -> Int:
    return 9

func state_resolver_order_motion() -> Int:
    return 10

func state_flags_has(flags: Int, bit: Int) -> Bool:
    if bit <= 0:
        return false
    let bucket: Int = flags / bit
    return bucket % 2 == 1

func state_flags_match(active_flags: Int, selector_flags: Int) -> Bool:
    if selector_flags == 0:
        return true
    if state_flags_has(selector_flags, 1):
        if !state_flags_has(active_flags, 1):
            return false
    if state_flags_has(selector_flags, 2):
        if !state_flags_has(active_flags, 2):
            return false
    if state_flags_has(selector_flags, 4):
        if !state_flags_has(active_flags, 4):
            return false
    if state_flags_has(selector_flags, 8):
        if !state_flags_has(active_flags, 8):
            return false
    if state_flags_has(selector_flags, 16):
        if !state_flags_has(active_flags, 16):
            return false
    if state_flags_has(selector_flags, 32):
        if !state_flags_has(active_flags, 32):
            return false
    if state_flags_has(selector_flags, 64):
        if !state_flags_has(active_flags, 64):
            return false
    return true

func state_selector_matches(active: StateSelector, selector: StateSelector) -> Bool:
    return state_flags_match(state_flags(active), state_flags(selector))

func state_resolve(base: StateSpec, override: StateSpec, active: StateSelector) -> StateSpec:
    if !state_flags_match(state_flags(active), override.selector_flags):
        return base
    var variant: Int = base.variant
    if override.variant != 0:
        variant = override.variant
    var selected: Bool = base.selected
    var disabled: Bool = base.disabled
    var error: Bool = base.error
    var loading: Bool = base.loading
    if override.selected:
        selected = true
    if override.disabled:
        disabled = true
    if override.error:
        error = true
    if override.loading:
        loading = true
    return StateSpec(
        selector_flags: base.selector_flags + override.selector_flags,
        variant: variant,
        selected: selected,
        disabled: disabled,
        error: error,
        loading: loading,
    )

func state_resolve_int(base: Int, override: Int, active: StateSelector, selector: StateSelector) -> Int:
    if state_selector_matches(active, selector):
        return override
    return base

func motion_ease_none() -> Int:
    return 0

func motion_ease_linear() -> Int:
    return 1

func motion_ease_standard() -> Int:
    return 2

func motion_quality_level() -> Int:
    return 1

func motion_clock_deterministic() -> Int:
    return 1

func motion_clamp_nonnegative(value: Int) -> Int:
    if value < 0:
        return 0
    return value

func motion_clamp_scale(value: Int) -> Int:
    if value <= 0:
        return 100
    return value

func motion_none() -> MotionSpec:
    return MotionSpec(
        duration_ms: 0,
        delay_ms: 0,
        easing: motion_ease_none(),
        reduced: false,
        animate_opacity: false,
        animate_color: false,
        animate_transform: false,
        translate_x: 0,
        translate_y: 0,
        scale: 100,
    )

func motion_fast() -> MotionSpec:
    return MotionSpec(
        duration_ms: 120,
        delay_ms: 0,
        easing: motion_ease_standard(),
        reduced: false,
        animate_opacity: true,
        animate_color: true,
        animate_transform: true,
        translate_x: 0,
        translate_y: 0,
        scale: 100,
    )

func motion_transition(duration_ms: Int, delay_ms: Int, easing: Int, animate_opacity: Bool, animate_color: Bool, animate_transform: Bool, translate_x: Int, translate_y: Int, scale: Int) -> MotionSpec:
    return MotionSpec(
        duration_ms: motion_clamp_nonnegative(duration_ms),
        delay_ms: motion_clamp_nonnegative(delay_ms),
        easing: easing,
        reduced: false,
        animate_opacity: animate_opacity,
        animate_color: animate_color,
        animate_transform: animate_transform,
        translate_x: translate_x,
        translate_y: translate_y,
        scale: motion_clamp_scale(scale),
    )

func motion_reduced(motion: MotionSpec) -> MotionSpec:
    return MotionSpec(
        duration_ms: motion.duration_ms,
        delay_ms: motion.delay_ms,
        easing: motion.easing,
        reduced: true,
        animate_opacity: motion.animate_opacity,
        animate_color: motion.animate_color,
        animate_transform: motion.animate_transform,
        translate_x: motion.translate_x,
        translate_y: motion.translate_y,
        scale: motion.scale,
    )

func motion_duration(motion: MotionSpec) -> Int:
    return motion.duration_ms

func motion_delay(motion: MotionSpec) -> Int:
    return motion.delay_ms

func motion_easing(motion: MotionSpec) -> Int:
    return motion.easing

func motion_total_ms(motion: MotionSpec) -> Int:
    return motion.delay_ms + motion.duration_ms

func motion_progress(motion: MotionSpec, elapsed_ms: Int) -> Int:
    if motion.reduced:
        return 1000
    if motion.duration_ms <= 0:
        return 1000
    if elapsed_ms <= motion.delay_ms:
        return 0
    let local_ms: Int = elapsed_ms - motion.delay_ms
    if local_ms >= motion.duration_ms:
        return 1000
    return local_ms * 1000 / motion.duration_ms

func motion_lerp_int(start: Int, finish: Int, progress: Int) -> Int:
    return start + (finish - start) * progress / 1000

func motion_resolve_int(start: Int, finish: Int, motion: MotionSpec, elapsed_ms: Int) -> Int:
    return motion_lerp_int(start, finish, motion_progress(motion, elapsed_ms))

func motion_resolve_opacity(start: Int, finish: Int, motion: MotionSpec, elapsed_ms: Int) -> Int:
    if !motion.animate_opacity:
        return start
    return motion_resolve_int(start, finish, motion, elapsed_ms)

func motion_resolve_color_channel(start: Int, finish: Int, motion: MotionSpec, elapsed_ms: Int) -> Int:
    if !motion.animate_color:
        return start
    return motion_resolve_int(start, finish, motion, elapsed_ms)

func motion_resolve_translate_x(motion: MotionSpec, elapsed_ms: Int) -> Int:
    if !motion.animate_transform:
        return 0
    return motion_resolve_int(0, motion.translate_x, motion, elapsed_ms)

func motion_resolve_translate_y(motion: MotionSpec, elapsed_ms: Int) -> Int:
    if !motion.animate_transform:
        return 0
    return motion_resolve_int(0, motion.translate_y, motion, elapsed_ms)

func motion_resolve_scale(motion: MotionSpec, elapsed_ms: Int) -> Int:
    if !motion.animate_transform:
        return 100
    return motion_resolve_int(100, motion.scale, motion, elapsed_ms)

func motion_is_complete(motion: MotionSpec, elapsed_ms: Int) -> Bool:
    return motion_progress(motion, elapsed_ms) >= 1000

func motion_should_schedule(motion: MotionSpec, elapsed_ms: Int) -> Bool:
    if motion.reduced:
        return false
    return !motion_is_complete(motion, elapsed_ms)

