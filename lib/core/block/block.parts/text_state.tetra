module lib.core.block

func text_none() -> TextSpec:
    return TextSpec(
        text_len: 0,
        r: 0,
        g: 0,
        b: 0,
        a: 0,
        font_size: 0,
        font_weight: 0,
        line_height: 0,
        flags: 0,
        placeholder_len: 0,
    )

func text_label(text_len: Int, color: surface.Color) -> TextSpec:
    return TextSpec(
        text_len: text_len,
        r: color.r,
        g: color.g,
        b: color.b,
        a: color.a,
        font_size: 14,
        font_weight: 400,
        line_height: 18,
        flags: 0,
        placeholder_len: 0,
    )

func text_editable(text_len: Int, placeholder_len: Int, color: surface.Color) -> TextSpec:
    return TextSpec(
        text_len: text_len,
        r: color.r,
        g: color.g,
        b: color.b,
        a: color.a,
        font_size: 14,
        font_weight: 400,
        line_height: 18,
        flags: 1,
        placeholder_len: placeholder_len,
    )

func text_family_system() -> Int:
    return 1

func text_family_ui() -> Int:
    return 2

func text_family_monospace() -> Int:
    return 3

func text_align_start() -> Int:
    return 1

func text_align_center() -> Int:
    return 2

func text_align_end() -> Int:
    return 3

func text_wrap_none() -> Int:
    return 0

func text_wrap_word() -> Int:
    return 1

func text_wrap_char() -> Int:
    return 2

func text_overflow_clip() -> Int:
    return 0

func text_overflow_ellipsis() -> Int:
    return 1

func text_feature_editable() -> Int:
    return 1

func text_feature_fallback() -> Int:
    return 2

func text_flags(family: Int, align: Int, wrap: Int, overflow: Int) -> Int:
    return text_feature_fallback() + family * 10 + align * 100 + wrap * 1000 + overflow * 10000

func text_flags_editable(family: Int, align: Int, wrap: Int, overflow: Int) -> Int:
    return text_flags(family, align, wrap, overflow) + text_feature_editable()

func text_clamp_opacity(opacity: Int, fallback: Int) -> Int:
    if opacity <= 0:
        return fallback
    if opacity > 255:
        return 255
    return opacity

func text_styled(text_len: Int, color: surface.Color, family: Int, font_size: Int, font_weight: Int, line_height: Int, align: Int, wrap: Int, overflow: Int, opacity: Int) -> TextSpec:
    return TextSpec(
        text_len: text_len,
        r: color.r,
        g: color.g,
        b: color.b,
        a: text_clamp_opacity(opacity, color.a),
        font_size: font_size,
        font_weight: font_weight,
        line_height: line_height,
        flags: text_flags(family, align, wrap, overflow),
        placeholder_len: 0,
    )

func text_editable_styled(text_len: Int, placeholder_len: Int, color: surface.Color, family: Int, font_size: Int, font_weight: Int, line_height: Int, align: Int, wrap: Int, overflow: Int, opacity: Int) -> TextSpec:
    return TextSpec(
        text_len: text_len,
        r: color.r,
        g: color.g,
        b: color.b,
        a: text_clamp_opacity(opacity, color.a),
        font_size: font_size,
        font_weight: font_weight,
        line_height: line_height,
        flags: text_flags_editable(family, align, wrap, overflow),
        placeholder_len: placeholder_len,
    )

func text_is_editable(spec: TextSpec) -> Bool:
    return spec.flags % 2 == 1

func text_has_fallback(spec: TextSpec) -> Bool:
    return spec.flags / text_feature_fallback() % 2 == 1

func text_family_value(spec: TextSpec) -> Int:
    let value: Int = spec.flags / 10 % 10
    if value <= 0:
        return text_family_system()
    return value

func text_align_value(spec: TextSpec) -> Int:
    let value: Int = spec.flags / 100 % 10
    if value <= 0:
        return text_align_start()
    return value

func text_wrap_value(spec: TextSpec) -> Int:
    return spec.flags / 1000 % 10

func text_overflow_value(spec: TextSpec) -> Int:
    return spec.flags / 10000 % 10

func text_effective_font_size(spec: TextSpec) -> Int:
    if spec.font_size <= 0:
        return 14
    return spec.font_size

func text_effective_line_height(spec: TextSpec) -> Int:
    if spec.line_height <= 0:
        return text_effective_font_size(spec) + 4
    return spec.line_height

func text_char_width(spec: TextSpec) -> Int:
    var width: Int = text_effective_font_size(spec) * 6 / 10
    if spec.font_weight >= 600:
        width = width + 1
    if text_family_value(spec) == text_family_monospace():
        width = width + 1
    if width < 1:
        return 1
    return width

func text_raw_width(spec: TextSpec) -> Int:
    return spec.text_len * text_char_width(spec)

func text_wrap_line_count(spec: TextSpec, max_width: Int) -> Int:
    if spec.text_len <= 0:
        return 1
    if text_wrap_value(spec) == text_wrap_none() || max_width <= 0:
        return 1
    let char_width: Int = text_char_width(spec)
    var chars_per_line: Int = max_width / char_width
    if chars_per_line < 1:
        chars_per_line = 1
    return (spec.text_len + chars_per_line - 1) / chars_per_line

func text_ellipsized_len(spec: TextSpec, max_width: Int) -> Int:
    if spec.text_len <= 0:
        return 0
    if text_overflow_value(spec) != text_overflow_ellipsis() || max_width <= 0:
        return spec.text_len
    let char_width: Int = text_char_width(spec)
    var chars: Int = max_width / char_width
    if chars >= spec.text_len:
        return spec.text_len
    if chars <= 3:
        return chars
    return chars - 3

func text_measure(spec: TextSpec, max_width: Int) -> surface.Size:
    let lines: Int = text_wrap_line_count(spec, max_width)
    var width: Int = text_raw_width(spec)
    if max_width > 0 && width > max_width:
        width = max_width
    if width <= 0 && spec.text_len > 0:
        width = text_char_width(spec)
    return surface.Size(w: width, h: text_effective_line_height(spec) * lines)

func text_measure_width(spec: TextSpec, max_width: Int) -> Int:
    let measured: surface.Size = text_measure(spec, max_width)
    return measured.w

func text_measure_height(spec: TextSpec, max_width: Int) -> Int:
    let measured: surface.Size = text_measure(spec, max_width)
    return measured.h

func text_font_fallback_chain_len(spec: TextSpec) -> Int:
    if text_has_fallback(spec):
        return 3
    return 1

func text_glyph_cache_budget_bytes() -> Int:
    return 65536

func text_glyph_cache_entry_limit() -> Int:
    return 512

func text_cache_error_ok() -> Int:
    return 0

func text_cache_error_unbounded() -> Int:
    return 1

func text_cache_error_over_budget() -> Int:
    return 2

func text_cache_error_too_many_entries() -> Int:
    return 3

func text_glyph_cache_validate(budget_bytes: Int, used_bytes: Int, entry_count: Int) -> Int:
    if budget_bytes <= 0 || budget_bytes > text_glyph_cache_budget_bytes():
        return text_cache_error_unbounded()
    if used_bytes < 0 || used_bytes > budget_bytes:
        return text_cache_error_over_budget()
    if entry_count < 0 || entry_count > text_glyph_cache_entry_limit():
        return text_cache_error_too_many_entries()
    return text_cache_error_ok()

func image_none() -> ImageSpec:
    return ImageSpec(
        asset_kind: 0,
        asset_index: -1,
        width: 0,
        height: 0,
        fit: 0,
        opacity: 0,
        tint_r: 0,
        tint_g: 0,
        tint_b: 0,
        tint_a: 0,
    )

func image_asset(asset: AssetRef, width: Int, height: Int) -> ImageSpec:
    return ImageSpec(
        asset_kind: asset.kind,
        asset_index: asset.index,
        width: width,
        height: height,
        fit: 1,
        opacity: 255,
        tint_r: 255,
        tint_g: 255,
        tint_b: 255,
        tint_a: 255,
