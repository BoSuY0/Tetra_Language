func token_ref(category: Int, index: Int, hash: Int) -> TokenRef:
    return TokenRef(category: category, index: index, hash: hash)

func token_category_supported(category: Int) -> Bool:
    let visual: Bool = category == token_color() || category == token_space()
    let visual_shape: Bool = visual || category == token_radius() || category == token_border()
    let surface: Bool = category == token_elevation() || category == token_opacity()
    let motion: Bool = category == token_typography() || category == token_motion()
    let output: Bool = category == token_z() || category == token_asset()
    return visual_shape || surface || motion || output || category == token_density()

func token_valid(token: TokenRef) -> Bool:
    return token_category_supported(token.category) && token.index >= 0 && token.hash > 0

func token_graph_policy_default() -> TokenGraphPolicy:
    return TokenGraphPolicy(
        source_hash: token_source_capsule_hash(),
        namespace_hash: token_namespace_app_hash(),
        override_order_hash: token_override_order_hash(),
        single_source: true,
        explicit_imports: true,
        no_global_cascade: true,
        diagnostic_flags: token_graph_diagnostic_flags(),
    )

func token_graph_policy_valid(policy: TokenGraphPolicy) -> Bool:
    let hashes: Bool = policy.source_hash == token_source_capsule_hash()
    let namespace: Bool = hashes && policy.namespace_hash == token_namespace_app_hash()
    let policy_hashes: Bool = namespace && policy.override_order_hash == token_override_order_hash()
    let flags: Bool = policy.single_source && policy.explicit_imports
    let policy_flags: Bool = flags && policy.no_global_cascade
    let diagnostics: Bool = policy.diagnostic_flags == token_graph_diagnostic_flags()
    return policy_hashes && policy_flags && diagnostics

func density_mapping_default() -> DensityMapping:
    return DensityMapping(
        target_hash: token_target_headless_hash(),
        token_hash: token_density_1x_hash(),
        target_dpi: 96,
        scale_milli: 1000,
        rounding_policy_hash: token_rounding_integer_half_up_hash(),
    )

func density_mapping_valid(mapping: DensityMapping) -> Bool:
    let identity: Bool = mapping.target_hash > 0 && mapping.token_hash == token_density_1x_hash()
    let scale: Bool = mapping.target_dpi >= 96 && mapping.scale_milli >= 1000
    let bounded_scale: Bool = scale && mapping.scale_milli <= 4000
    let rounding: Bool = mapping.rounding_policy_hash == token_rounding_integer_half_up_hash()
    return identity && bounded_scale && rounding

func capsule_default() -> Capsule:
    return Capsule(
        schema: schema_v1(),
        version: 1,
        token_graph_hash: 760031,
        recipe_count: 19,
        explicit_imports: true,
        isolated_scope: true,
        no_global_cascade: true,
        alias_cycle_rejected: true,
        duplicate_recipe_rejected: true,
        output_kind: output_block(),
    )

func capsule_valid(capsule: Capsule) -> Bool:
    let identity: Bool = capsule.schema == schema_v1() && capsule.version == 1
    let capsule_identity: Bool = identity && capsule.token_graph_hash > 0
    let capsule_counts: Bool = capsule_identity && capsule.recipe_count == 19
    let scope: Bool = capsule.explicit_imports && capsule.isolated_scope
    let capsule_scope: Bool = scope && capsule.no_global_cascade
    let rejection: Bool = capsule.alias_cycle_rejected && capsule.duplicate_recipe_rejected
    return capsule_counts && capsule_scope && rejection && capsule.output_kind == output_block()

