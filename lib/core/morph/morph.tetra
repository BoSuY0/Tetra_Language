func affordance_valid(affordance: Affordance) -> Bool:
    let input: Bool = affordance.role == block.accessibility_role_button()
    let input_role: Bool = input || affordance.role == block.accessibility_role_textbox()
    let content: Bool = affordance.role == block.accessibility_role_text()
    let content_role: Bool = content || affordance.role == block.accessibility_role_checkbox()
    let layout: Bool = affordance.role == block.accessibility_role_navigation()
    let layout_role: Bool = layout || affordance.role == block.accessibility_role_region()
    let overlays: Bool = affordance.role == block.accessibility_role_dialog()
    let overlay_role: Bool = overlays || affordance.role == block.accessibility_role_status()
    let known_role: Bool = input_role || content_role || layout_role || overlay_role
    return affordance.projects_accessibility && known_role

func state_lens_base() -> StateLens:
    return StateLens(selector_flags: 0, variant: 0, deterministic: true)

func state_lens_focus_flags() -> Int:
    return block.state_flags(block.state_selector_focused())

func state_lens_focus() -> StateLens:
    return StateLens(selector_flags: state_lens_focus_flags(), variant: 2, deterministic: true)

func state_lens_valid(lens: StateLens) -> Bool:
    return lens.selector_flags >= 0 && lens.variant >= 0 && lens.deterministic

func motion_preset_fast() -> MotionPreset:
    return MotionPreset(
        duration_ms: 120,
        easing: block.motion_ease_standard(),
        deterministic_clock: true,
        reduced_motion_supported: true,
    )

func motion_preset_panel() -> MotionPreset:
    return MotionPreset(
        duration_ms: 180,
        easing: block.motion_ease_standard(),
        deterministic_clock: true,
        reduced_motion_supported: true,
    )

func motion_preset_valid(preset: MotionPreset) -> Bool:
    let timing: Bool = preset.duration_ms >= 0 && preset.easing == block.motion_ease_standard()
    return timing && preset.deterministic_clock && preset.reduced_motion_supported

