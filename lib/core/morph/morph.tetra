    return Material(
        fill_hash: 2011,
        border_hash: 2012,
        radius_hash: 2013,
        shadow_hash: 2014,
        overlay_hash: 2015,
        layer_count: 5,
        unsupported_blur: false,
        unsupported_blur_rejected: true,
    )

func material_control() -> Material:
