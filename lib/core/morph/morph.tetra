    let icon_soft: surface.Color = surface.Color(r: 236, g: 238, b: 241, a: 255)
    let icon_line: surface.Color = surface.Color(r: 180, g: 188, b: 198, a: 255)
    let accent_line: surface.Color = surface.Color(r: 96, g: 174, b: 244, a: 255)
    let page_rect: surface.Rect = surface.Rect(x: 0, y: 0, w: frame.width, h: frame.height)
    let title_bar: surface.Rect = surface.Rect(x: 50, y: 42, w: 360, h: 12)
    let recent_panel: surface.Rect = surface.Rect(x: 50, y: 75, w: 1692, h: 212)
    let recent_title: surface.Rect = surface.Rect(x: 68, y: 104, w: 300, h: 8)
    let recent_icon: surface.Rect = surface.Rect(x: 866, y: 136, w: 60, h: 72)
    let recent_icon_page: surface.Rect = surface.Rect(x: 881, y: 150, w: 30, h: 42)
    let recent_icon_line1: surface.Rect = surface.Rect(x: 889, y: 162, w: 15, h: 3)
    let recent_icon_line2: surface.Rect = surface.Rect(x: 889, y: 172, w: 15, h: 3)
    let recent_empty: surface.Rect = surface.Rect(x: 820, y: 238, w: 260, h: 6)
    let overview_panel: surface.Rect = surface.Rect(x: 50, y: 305, w: 1692, h: 382)
    let overview_title: surface.Rect = surface.Rect(x: 68, y: 335, w: 250, h: 8)
    let divider: surface.Rect = surface.Rect(x: 68, y: 360, w: 1656, h: 1)
    let overview_icon: surface.Rect = surface.Rect(x: 866, y: 382, w: 60, h: 72)
    let overview_icon_page: surface.Rect = surface.Rect(x: 881, y: 396, w: 30, h: 42)
    let overview_icon_line1: surface.Rect = surface.Rect(x: 889, y: 408, w: 15, h: 3)
    let overview_icon_line2: surface.Rect = surface.Rect(x: 889, y: 418, w: 15, h: 3)
    let overview_headline: surface.Rect = surface.Rect(x: 755, y: 493, w: 370, h: 8)
    let overview_body1: surface.Rect = surface.Rect(x: 725, y: 527, w: 430, h: 5)
    let overview_body2: surface.Rect = surface.Rect(x: 768, y: 542, w: 344, h: 5)
    let d0: Int = render_frame_rect(frame, page_rect, bg)
    let d1: Int = render_frame_rect(frame, recent_panel, panel_bg)
    let d2: Int = render_frame_outline(frame, recent_panel, panel_line)
    let d3: Int = render_frame_rect(frame, title_bar, heading)
    let d4: Int = render_frame_rect(frame, recent_title, heading)
    let d5: Int = render_frame_rect(frame, recent_icon, icon_soft)
    let d6: Int = render_frame_outline(frame, recent_icon, panel_line)
    let d7: Int = render_frame_rect(frame, recent_icon_page, bg)
    let d8: Int = render_frame_outline(frame, recent_icon_page, icon_line)
    let d9: Int = render_frame_rect(frame, recent_icon_line1, icon_line)
    let d10: Int = render_frame_rect(frame, recent_icon_line2, icon_line)
    let d11: Int = render_frame_rect(frame, recent_empty, body)
    let d12: Int = render_frame_rect(frame, overview_panel, panel_bg)
    let d13: Int = render_frame_outline(frame, overview_panel, panel_line)
    let d14: Int = render_frame_rect(frame, overview_title, heading)
    let d15: Int = render_frame_rect(frame, divider, panel_line)
    let d16: Int = render_frame_rect(frame, overview_icon, icon_soft)
    let d17: Int = render_frame_outline(frame, overview_icon, panel_line)
    let d18: Int = render_frame_rect(frame, overview_icon_page, bg)
    let d19: Int = render_frame_outline(frame, overview_icon_page, icon_line)
    let d20: Int = render_frame_rect(frame, overview_icon_line1, icon_line)
    let d21: Int = render_frame_rect(frame, overview_icon_line2, icon_line)
    let d22: Int = render_frame_rect(frame, overview_headline, heading)
    let d23: Int = render_frame_rect(frame, overview_body1, body)
    let d24: Int = render_frame_rect(frame, overview_body2, body)
    if active:
        let active_bar: surface.Rect = surface.Rect(x: 50, y: 75, w: 1692, h: 3)
        let active_recent: surface.Rect = surface.Rect(x: 862, y: 132, w: 68, h: 80)
        let active_overview: surface.Rect = surface.Rect(x: 862, y: 378, w: 68, h: 80)
        let d25: Int = render_frame_rect(frame, active_bar, accent_line)
        let d26: Int = render_frame_outline(frame, active_recent, accent_line)
        let d27: Int = render_frame_outline(frame, active_overview, accent_line)
    return 0

func panel_paint() -> block.PaintSpec:
    let fill_c: surface.Color = surface.Color(r: 24, g: 31, b: 38, a: 255)
    let grad_a: surface.Color = surface.Color(r: 28, g: 38, b: 48, a: 255)
    let grad_b: surface.Color = surface.Color(r: 38, g: 54, b: 66, a: 255)
    let border_c: surface.Color = surface.Color(r: 82, g: 104, b: 124, a: 255)
    let shadow_c: surface.Color = surface.Color(r: 0, g: 0, b: 0, a: 128)
    let fill: block.PaintLayer = block.paint_layer_fill_radius(fill_c, 18)
    let grad: block.PaintLayer = block.paint_layer_linear_gradient(grad_a, grad_b, 18)
    let border: block.PaintLayer = block.paint_layer_border(border_c, 1, 18)
    let shadow: block.PaintLayer = block.paint_layer_shadow(shadow_c, 24, 0, 10)
    let outline: block.PaintLayer = block.paint_layer_outline(accent(), 1, 20)
    return block.paint_stack5(fill, grad, border, shadow, outline)

func control_paint(selected: Bool) -> block.PaintSpec:
    if selected:
        let selected_fill_c: surface.Color = surface.Color(r: 44, g: 70, b: 92, a: 255)
        let grad_a: surface.Color = surface.Color(r: 52, g: 92, b: 126, a: 255)
        let grad_b: surface.Color = surface.Color(r: 44, g: 72, b: 96, a: 255)
        let selected_shadow_c: surface.Color = surface.Color(r: 0, g: 0, b: 0, a: 72)
        let selected_fill: block.PaintLayer = block.paint_layer_fill_radius(selected_fill_c, 12)
        let selected_grad: block.PaintLayer = block.paint_layer_linear_gradient(grad_a, grad_b, 12)
        let selected_border: block.PaintLayer = block.paint_layer_border(accent(), 1, 12)
        let selected_shadow = block.paint_layer_shadow(selected_shadow_c, 10, 0, 3)
        return block.paint_stack4(selected_fill, selected_grad, selected_border, selected_shadow)
    let idle_fill_c: surface.Color = surface.Color(r: 30, g: 38, b: 46, a: 255)
    let border_c: surface.Color = surface.Color(r: 50, g: 62, b: 74, a: 255)
    let idle_shadow_c: surface.Color = surface.Color(r: 0, g: 0, b: 0, a: 48)
    let idle_fill: block.PaintLayer = block.paint_layer_fill_radius(idle_fill_c, 12)
    let idle_border: block.PaintLayer = block.paint_layer_border(border_c, 1, 12)
    let idle_shadow: block.PaintLayer = block.paint_layer_shadow(idle_shadow_c, 8, 0, 2)
    return block.paint_stack3(idle_fill, idle_border, idle_shadow)

func field_paint() -> block.PaintSpec:
    let fill_c: surface.Color = surface.Color(r: 12, g: 16, b: 20, a: 255)
    let border_c: surface.Color = surface.Color(r: 76, g: 92, b: 108, a: 255)
    let fill: block.PaintLayer = block.paint_layer_fill_radius(fill_c, 12)
    let border: block.PaintLayer = block.paint_layer_border(border_c, 1, 12)
    let outline: block.PaintLayer = block.paint_layer_outline(accent(), 1, 14)
    return block.paint_stack3(fill, border, outline)

func expand_region_panel(id: Int, p: Int, r: surface.Rect, label: Int) -> block.Block:
    let ease: Int = block.motion_ease_standard()
    let l: block.LayoutSpec = block.layout_column(r, 10)
    let paint: block.PaintSpec = panel_paint()
    let t: block.TextSpec = block.text_none()
    let i: block.ImageSpec = block.image_none()
    let n: block.InputSpec = block.input_none()
    let e: block.EventSpec = block.event_none()
    let s: block.StateSpec = block.state_base()
    let m: block.MotionSpec = block.motion_transition(180, 0, ease, true, true, true, 0, 8, 100)
    let a: block.AccessibilitySpec = block.accessibility_text(label)
    let asset: block.AssetRef = block.asset_none()
    let props: block.BlockProps = block.props(l, paint, t, i, n, e, s, m, a, asset)
    return block.make(block.id(id), block.id(p), props)

func expand_control_action(x: Int, p: Int, r: surface.Rect, l: Int, i: Int, s: Bool) -> block.Block:
    let asset: block.AssetRef = block.asset_icon(x, 16, 16, i)
    let image: block.ImageSpec = block.image_asset_tinted_scaled(asset, 16, 16, accent(), 1)
    let c: surface.Color = theme_light()
    let f: Int = block.text_family_ui()
    let al: Int = block.text_align_start()
    let wr: Int = block.text_wrap_none()
    let ov: Int = block.text_overflow_ellipsis()
    let t: block.TextSpec = block.text_styled(l, c, f, 14, 600, 18, al, wr, ov, 255)
    var state: block.StateSpec = block.state_interactive()
    if s:
        state = block.state_with_selector(block.state_selector_focused(), 2)
    let ease: Int = block.motion_ease_standard()
    let m: block.MotionSpec = block.motion_transition(120, 0, ease, true, true, true, 0, -2, 102)
    let layout: block.LayoutSpec = block.layout_row(r, 10)
    let paint: block.PaintSpec = control_paint(s)
    let n: block.InputSpec = block.input_clickable()
    let e: block.EventSpec = block.event_click(block.action_primary())
    let a: block.AccessibilitySpec = block.accessibility_button(l)
    let props: block.BlockProps = block.props(layout, paint, t, image, n, e, state, m, a, asset)
    return block.make(block.id(x), block.id(p), props)

func expand_field_text(x: Int, p: Int, lid: Int, r: surface.Rect, n: Int, ph: Int) -> block.Block:
    let label_id: block.BlockID = block.id(lid)
    let c: surface.Color = theme_light()
    let f: Int = block.text_family_ui()
    let al: Int = block.text_align_start()
    let wr: Int = block.text_wrap_none()
    let ov: Int = block.text_overflow_ellipsis()
    let t: block.TextSpec = block.text_editable_styled(n, ph, c, f, 15, 500, 20, al, wr, ov, 255)
    let l: block.LayoutSpec = block.layout_row(r, 8)
    let paint: block.PaintSpec = field_paint()
    let i: block.ImageSpec = block.image_none()
    let input: block.InputSpec = block.input_text()
    let e: block.EventSpec = block.event_text(block.action_primary())
    let s: block.StateSpec = block.state_interactive()
    let m: block.MotionSpec = block.motion_fast()
    let a: block.AccessibilitySpec = block.accessibility_textbox_labelled_by(n, label_id)
    let asset: block.AssetRef = block.asset_font(1, 9001)
    let props: block.BlockProps = block.props(l, paint, t, i, input, e, s, m, a, asset)
    return block.make(block.id(x), block.id(p), props)

func expand_label(x: Int, p: Int, target: Int, r: surface.Rect, label: Int) -> block.Block:
    let target_id: block.BlockID = block.id(target)
    let c: surface.Color = muted()
    let f: Int = block.text_family_ui()
    let al: Int = block.text_align_start()
    let wr: Int = block.text_wrap_none()
    let ov: Int = block.text_overflow_ellipsis()
    let t: block.TextSpec = block.text_styled(label, c, f, 12, 500, 16, al, wr, ov, 255)
    let l: block.LayoutSpec = block.layout_fixed(r)
    let paint: block.PaintSpec = block.paint_empty()
    let i: block.ImageSpec = block.image_none()
    let n: block.InputSpec = block.input_none()
    let e: block.EventSpec = block.event_none()
    let s: block.StateSpec = block.state_base()
    let m: block.MotionSpec = block.motion_none()
    let a: block.AccessibilitySpec = block.accessibility_label_for(label, target_id)
    let asset: block.AssetRef = block.asset_none()
    let props: block.BlockProps = block.props(l, paint, t, i, n, e, s, m, a, asset)
    return block.make(block.id(x), block.id(p), props)

func accessibility_projection_ok(label_id_value: Int, field_id_value: Int, label_len: Int) -> Bool:
    let label_id: block.BlockID = block.id(label_id_value)
    let field_id: block.BlockID = block.id(field_id_value)
    let label: block.AccessibilitySpec = block.accessibility_label_for(label_len, field_id)
    let len: Int = label_len
    let field: block.AccessibilitySpec = block.accessibility_textbox_labelled_by(len, label_id)
    let named: Bool = block.accessibility_focusable_has_name(field)
    let related: Bool = block.accessibility_relationship_matches(label, field, label_id, field_id)
    return named && related

func memory_budget_ok(block_count: Int, asset_count: Int, framebuffer_bytes: Int) -> Bool:
    let blocks_ok: Bool = block_count <= 64
    let assets_ok: Bool = asset_count <= block.asset_cache_entry_limit()
    let frame_ok: Bool = framebuffer_bytes <= block.asset_cache_budget_bytes()
    return blocks_ok && assets_ok && frame_ok

func capsule_self_check() -> Bool:
    let capsule: Capsule = capsule_default()
    let materials_a: Bool = material_valid(material_panel()) && material_valid(material_control())
    let materials: Bool = materials_a && material_valid(material_field())
    let affordance_a: Bool = affordance_valid(affordance_action())
    let affordance_b: Bool = affordance_a && affordance_valid(affordance_text_field())
    let affordance_c: Bool = affordance_b && affordance_valid(affordance_toggle())
    let affordance_d: Bool = affordance_c && affordance_valid(affordance_navigation())
    let affordance_e: Bool = affordance_d && affordance_valid(affordance_region())
    let affordance_f: Bool = affordance_e && affordance_valid(affordance_overlay())
    let affordances: Bool = affordance_f && affordance_valid(affordance_status())
    let lenses: Bool = state_lens_valid(state_lens_base()) && state_lens_valid(state_lens_focus())
    let motion: Bool = motion_preset_valid(motion_preset_fast())
    let motions: Bool = motion && motion_preset_valid(motion_preset_panel())
    let recipes_a: Bool = recipe_safe(recipe_control_action()) && recipe_safe(recipe_field_text())
    let recipes_b: Bool = recipes_a && recipe_safe(recipe_command_item())
    let recipes_c: Bool = recipes_b && recipe_safe(recipe_region_panel())
    let recipes_d: Bool = recipes_c && recipe_safe(recipe_form_field())
    let recipes_e: Bool = recipes_d && recipe_safe(recipe_nav_item())
    let recipes_f: Bool = recipes_e && recipe_safe(recipe_metric_tile())
    let recipes_g: Bool = recipes_f && recipe_safe(recipe_dialog_panel())
    let recipes_h: Bool = recipes_g && recipe_safe(recipe_toast_notification())
    let recipes_i: Bool = recipes_h && recipe_safe(recipe_tab_item())
    let recipes_j: Bool = recipes_i && recipe_safe(recipe_list_row())
    let recipes_k: Bool = recipes_j && recipe_safe(recipe_app_shell())
    let recipes_l: Bool = recipes_k && recipe_safe(recipe_toolbar())
    let recipes_m: Bool = recipes_l && recipe_safe(recipe_split_pane())
    let recipes_n: Bool = recipes_m && recipe_safe(recipe_status_bar())
    let recipes_o: Bool = recipes_n && recipe_safe(recipe_settings_form())
    let recipes_p: Bool = recipes_o && recipe_safe(recipe_log_row())
    let recipes_q: Bool = recipes_p && recipe_safe(recipe_empty_state())
    let recipes: Bool = recipes_q && recipe_safe(recipe_error_panel())
    let primitives: Bool = capsule_valid(capsule) && materials && affordances
    return primitives && lenses && motions && recipes
