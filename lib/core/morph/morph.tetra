// Experimental Surface Morph Capsule layer.
// Morph recipes project into lib.core.block Blocks; they do not add runtime primitives.
// Effects: mem
// ```tetra doctest
// func morph_doctest() -> Int:
//     let capsule: lib.core.morph.Capsule = lib.core.morph.capsule_default()
//     let recipe: lib.core.morph.Recipe = lib.core.morph.recipe_control_action()
//     if lib.core.morph.capsule_valid(capsule) && lib.core.morph.recipe_expands_to_block(recipe):
//         return lib.core.morph.schema_v1()
//     return 0
// ```
module lib.core.morph

import lib.core.surface as surface
import lib.core.block as block

struct Capsule:
    schema: Int
    version: Int
    token_graph_hash: Int
    recipe_count: Int
    explicit_imports: Bool
    isolated_scope: Bool
    no_global_cascade: Bool
    alias_cycle_rejected: Bool
    duplicate_recipe_rejected: Bool
    output_kind: Int

struct TokenRef:
    category: Int
    index: Int
    hash: Int

struct TokenGraphPolicy:
    source_hash: Int
    namespace_hash: Int
    override_order_hash: Int
    single_source: Bool
    explicit_imports: Bool
    no_global_cascade: Bool
    diagnostic_flags: Int

struct DensityMapping:
    target_hash: Int
    token_hash: Int
    target_dpi: Int
    scale_milli: Int
    rounding_policy_hash: Int

struct Material:
    fill_hash: Int
    border_hash: Int
    radius_hash: Int
    shadow_hash: Int
    overlay_hash: Int
    layer_count: Int
    unsupported_blur: Bool
    unsupported_blur_rejected: Bool

struct Affordance:
    role: Int
    focusable: Bool
    accepts_action: Bool
    accepts_text: Bool
    projects_accessibility: Bool

struct StateLens:
    selector_flags: Int
    variant: Int
    deterministic: Bool

struct MotionPreset:
    duration_ms: Int
    easing: Int
    deterministic_clock: Bool
    reduced_motion_supported: Bool

struct Recipe:
    name_hash: Int
    output_kind: Int
    slot_count: Int
    input_count: Int
    hidden_app_state: Bool
    platform_widgets: Bool
    core_primitive_promotion: Bool
    deterministic: Bool

struct RecipeExpansion:
    recipe_hash: Int
    block_id: block.BlockID
    output_kind: Int
    slot_count: Int
    reported: Bool
    deterministic: Bool
    used_block_graph: Bool

