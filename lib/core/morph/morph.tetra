    let ______: Int = render_frame_rect(frame, content_rect, content_color)
    let _______: Int = render_frame_rect(frame, command_rect, action)
    let ________: Int = render_frame_rect(frame, metric_rect, accent())
    let _________: Int = render_frame_rect(frame, log_rect, soft_text)
    let __________: Int = render_frame_rect(frame, status_rect, success)
    let ___________: Int = render_frame_outline(frame, command_rect, fg)
    let nav_line_1: surface.Rect = rect(nav_rect.x + 12, nav_rect.y + 14, nav_rect.w - 24, 8)
    let nav_line_2: surface.Rect = rect(nav_rect.x + 12, nav_rect.y + 34, nav_rect.w - 24, 8)
    let nav_line_3: surface.Rect = rect(nav_rect.x + 12, nav_rect.y + 54, nav_rect.w - 24, 8)
    let ____________: Int = render_frame_rect(frame, nav_line_1, accent())
    let _____________: Int = render_frame_rect(frame, nav_line_2, soft_text)
    let ______________: Int = render_frame_rect(frame, nav_line_3, soft_text)
    if active:
        let focus_command: surface.Rect = focus_rect(command_rect)
        let focus_metric: surface.Rect = focus_rect(metric_rect)
        let _______________: Int = render_frame_outline(frame, focus_command, focus)
        let ________________: Int = render_frame_outline(frame, focus_metric, focus)
        let command_mark: surface.Rect = rect(command_rect.x + 14, command_rect.y + 12, 72, 6)
        let _________________: Int = render_frame_rect(frame, command_mark, bg)
    return 0

func render_guest_dashboard_frame(active: Bool, frame: inout surface.Frame) -> Int
uses mem:
    let bg: surface.Color = surface.Color(r: 255, g: 255, b: 255, a: 255)
    let panel_bg: surface.Color = surface.Color(r: 252, g: 253, b: 255, a: 255)
