func material_valid(material: Material) -> Bool:
    let base: Bool = material.fill_hash > 0 && material.border_hash > 0
    let material_base: Bool = base && material.radius_hash > 0 && material.shadow_hash > 0
    let overlay: Bool = material.overlay_hash > 0 && material.layer_count > 0
    let supported: Bool = !material.unsupported_blur && material.unsupported_blur_rejected
    return material_base && overlay && supported

func affordance_action() -> Affordance:
    return Affordance(
        role: block.accessibility_role_button(),
        focusable: true,
        accepts_action: true,
        accepts_text: false,
        projects_accessibility: true,
    )

