func recipe_safe(recipe: Recipe) -> Bool:
    let shape: Bool = recipe.name_hash > 0 && recipe.output_kind == output_block()
    let recipe_shape: Bool = shape && recipe.slot_count <= 8 && recipe.input_count > 0
    let no_escape: Bool = !recipe.hidden_app_state && !recipe.platform_widgets
    let no_primitive_escape: Bool = no_escape && !recipe.core_primitive_promotion
    return recipe_shape && no_primitive_escape && recipe.deterministic

func recipe_expansion(recipe: Recipe, block_id: block.BlockID) -> RecipeExpansion:
    return RecipeExpansion(
        recipe_hash: recipe.name_hash,
        block_id: block_id,
        output_kind: recipe.output_kind,
        slot_count: recipe.slot_count,
        reported: true,
        deterministic: recipe.deterministic,
        used_block_graph: true,
    )

func recipe_expands_to_block(recipe: Recipe) -> Bool:
    return recipe_safe(recipe) && recipe.output_kind == output_block()

func expansion_valid(expansion: RecipeExpansion) -> Bool:
    let identity: Bool = expansion.recipe_hash > 0 && block.id_value(expansion.block_id) > 0
    let shape: Bool = expansion.output_kind == output_block() && expansion.slot_count <= 8
    let reported: Bool = expansion.reported && expansion.deterministic
    return identity && shape && reported && expansion.used_block_graph

func accent() -> surface.Color:
    return surface.Color(r: 96, g: 174, b: 244, a: 255)

func theme_dark() -> surface.Color:
    return surface.Color(r: 14, g: 18, b: 22, a: 255)

func theme_light() -> surface.Color:
    return surface.Color(r: 244, g: 247, b: 250, a: 255)

func muted() -> surface.Color:
    return surface.Color(r: 126, g: 144, b: 163, a: 255)

func rect(x: Int, y: Int, w: Int, h: Int) -> surface.Rect:
    return surface.Rect(x: x, y: y, w: w, h: h)

func focus_rect(r: surface.Rect) -> surface.Rect:
    return rect(r.x - 3, r.y - 3, r.w + 6, r.h + 6)

func render_frame_clear(frame: inout surface.Frame, color: surface.Color) -> Int
uses mem:
    var y: Int = 0
    while y < frame.height:
        var x: Int = 0
        while x < frame.width:
            let i: Int = y * frame.stride + x * 4
            frame.pixels[i] = color.r
            // MRB-12 evidence bridge only: Morph-authored flagship pixels for smoke gates.
            // Stable promotion must keep recipes Block-first and use renderer-owned proof.
            frame.pixels[i + 1] = color.g
            frame.pixels[i + 2] = color.b
            frame.pixels[i + 3] = color.a
            x = x + 1
        y = y + 1
    return 0

func render_frame_rect(frame: inout surface.Frame, rect: surface.Rect, color: surface.Color) -> Int
uses mem:
    var y: Int = rect.y
    let max_y: Int = rect.y + rect.h
    let max_x: Int = rect.x + rect.w
    while y < max_y:
        var x: Int = rect.x
        while x < max_x:
            if x >= 0 && y >= 0 && x < frame.width && y < frame.height:
                let i: Int = y * frame.stride + x * 4
                frame.pixels[i] = color.r
                frame.pixels[i + 1] = color.g
                frame.pixels[i + 2] = color.b
                frame.pixels[i + 3] = color.a
            x = x + 1
        y = y + 1
    return 0

func render_frame_outline(frame: inout surface.Frame, r: surface.Rect, color: surface.Color) -> Int
uses mem:
    let top: surface.Rect = surface.Rect(x: r.x, y: r.y, w: r.w, h: 1)
    let bottom: surface.Rect = surface.Rect(x: r.x, y: r.y + r.h - 1, w: r.w, h: 1)
    let left: surface.Rect = surface.Rect(x: r.x, y: r.y, w: 1, h: r.h)
    let right: surface.Rect = surface.Rect(x: r.x + r.w - 1, y: r.y, w: 1, h: r.h)
    let _: Int = render_frame_rect(frame, top, color)
    let __: Int = render_frame_rect(frame, bottom, color)
    let ___: Int = render_frame_rect(frame, left, color)
    return render_frame_rect(frame, right, color)

func render_studio_shell_frame(active: Bool, frame: inout surface.Frame) -> Int
uses mem:
    let bg: surface.Color = theme_dark()
    let panel: surface.Color = surface.Color(r: 32, g: 42, b: 50, a: 255)
    let panel_soft: surface.Color = surface.Color(r: 45, g: 58, b: 70, a: 255)
    let fg: surface.Color = surface.Color(r: 232, g: 238, b: 244, a: 255)
    let soft_text: surface.Color = surface.Color(r: 150, g: 166, b: 184, a: 255)
    let action: surface.Color = surface.Color(r: 64, g: 112, b: 148, a: 255)
    let success: surface.Color = surface.Color(r: 84, g: 180, b: 132, a: 255)
    var focus: surface.Color = surface.Color(r: 244, g: 205, b: 92, a: 255)
    if active:
        focus = accent()
    let width: Int = frame.width
    let height: Int = frame.height
    let shell_rect: surface.Rect = rect(8, 8, width - 16, height - 16)
    let nav_rect: surface.Rect = rect(18, 28, 72, height - 56)
    let toolbar_rect: surface.Rect = rect(102, 28, width - 122, 32)
    let content_rect: surface.Rect = rect(102, 72, width - 122, height - 114)
    let command_rect: surface.Rect = rect(118, 86, width - 154, 30)
    let metric_rect: surface.Rect = rect(118, 130, 86, 40)
    let log_rect: surface.Rect = rect(216, 130, width - 252, 40)
    let status_rect: surface.Rect = rect(102, height - 34, width - 122, 18)
    let _: Int = render_frame_clear(frame, bg)
    let __: Int = render_frame_rect(frame, shell_rect, panel)
    let ___: Int = render_frame_outline(frame, shell_rect, fg)
    let ____: Int = render_frame_rect(frame, nav_rect, panel_soft)
    let _____: Int = render_frame_rect(frame, toolbar_rect, panel_soft)
