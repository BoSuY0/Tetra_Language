// MMIO smoke test
// Uses capability-gated MMIO read/write on a heap buffer.

fun main(): i32 {
    var out: i32 = 0
    unsafe {
        let io: cap.io = core.cap_io()
        let p: ptr = core.alloc_bytes(4)
        let _w: i32 = core.mmio_write_i32(p, 123, io)
        out = core.mmio_read_i32(p, io)
    }
    return out
}
