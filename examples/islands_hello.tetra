// Islands smoke test
// Creates a scoped island, allocates a []u8, writes "Hello\n", prints it.
func main() -> i32
uses alloc, io, islands, mem:
    island(64) as isl:
        // 'H'
        var msg: []u8 = core.island_make_u8(isl, 6)
        // 'e'
        msg[0] = 72
        // 'l'
        msg[1] = 101
        // 'l'
        msg[2] = 108
        // 'o'
        msg[3] = 108
        // '\n'
        msg[4] = 111
        msg[5] = 10
        print(msg)
    return 0
