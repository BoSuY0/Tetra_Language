// Stable core filesystem stdlib smoke.
module examples.core_filesystem_smoke

import lib.core.filesystem as filesystem

func main() -> Int:
    let depth: Int = filesystem.directory_depth("/tmp/cache")
    let slash_count: Int = filesystem.slash_count("/tmp/cache")
    if filesystem.has_leading_slash("/tmp") && depth == 2 && slash_count == 2 && filesystem.is_root("/"):
        return 42
    return 1
