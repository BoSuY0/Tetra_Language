// Stable core time stdlib smoke.
module examples.core_time_smoke

import lib.core.time as time_lib

func main() -> Int:
    let millis: Int = time_lib.millis_from_seconds(7)
    let seconds: Int = time_lib.seconds_from_millis(42000)
    let timeout: Int = time_lib.clamp_timeout_ms(millis, 0, 42000)
    if timeout == 7000 && seconds == 42 && time_lib.add_duration_ms(2, 40) == 42:
        return 42
    return 1
