// Test command compiler microservice smoke.
//
// The service includes a Tetra test declaration for the CLI test runner while
// keeping the executable entrypoint as a zero-exit microservice.
module examples.microservices.compiler.pipeline.compiler_test_command_service
func add(a: Int, b: Int) -> Int:
    return a + b

func main() -> Int:
    let value: Int = add(20, 22)
    if value == 42:
        return 0
    return value

test "adds":
    expect add(20, 22) == 42
