// Inout return-value microservice smoke.
//
// The service uses the current supported scalar inout path by consuming the
// returned value explicitly instead of relying on caller-local writeback.
module examples.microservices.compiler.callables.compiler_inout_return_service
func bump(value: inout Int) -> Int:
    value = value + 1
    return value

func main() -> Int:
    var score: Int = 41
    let returned: Int = bump(score)
    if returned == 42:
        return 0
    return returned
