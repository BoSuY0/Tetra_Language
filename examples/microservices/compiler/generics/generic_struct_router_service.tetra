// Generic struct router microservice smoke.
//
// The service routes an Int status through a generic struct plus a generic
// wrapper function in one module.
module examples.microservices.compiler.generics.generic_struct_router_service
struct Envelope<T>:
    value: T

func wrap<T>(value: T) -> Envelope<T>:
    return Envelope<T>(value: value)

func main() -> Int:
    let envelope: Envelope<Int> = wrap(42)
    if envelope.value == 42:
        return 0
    return envelope.value
