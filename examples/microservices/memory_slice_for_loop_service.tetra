// Slice for-loop memory microservice smoke.
//
// The service fills a heap-backed []u8 and sums it through collection-loop
// lowering.
module examples.microservices.memory_slice_for_loop_service

func main() -> Int
uses alloc, mem:
    var bytes: []u8 = core.make_u8(4)
    bytes[0] = 7
    bytes[1] = 8
    bytes[2] = 12
    bytes[3] = 15
    var total: Int = 0
    for b in bytes:
        total = total + b
    if total == 42:
        return 0
    return total
