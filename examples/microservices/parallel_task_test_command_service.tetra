// Task test-command microservice smoke.
//
// The service combines a Tetra test declaration with a runtime task join in
// the executable path.
module examples.microservices.parallel_task_test_command_service

func worker() -> Int:
    return 42

func main() -> Int
uses runtime:
    let task: task.i32 = core.task_spawn_i32("worker")
    let result: task.result_i32 = core.task_join_result_i32(task)
    if result.error != 0:
        return 10 + result.error
    if result.value == 42:
        return 0
    return result.value

test "worker value":
    expect worker() == 42
