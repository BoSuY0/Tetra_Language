// U16 slice for-loop memory microservice smoke.
//
// The service fills a heap-backed []u16 and sums it through collection-loop
// lowering.
module examples.microservices.memory.scalars.loops.memory_u16_for_loop_service
func main() -> Int
uses alloc, mem:
    var nums: []u16 = core.make_u16(4)
    nums[0] = 3
    nums[1] = 9
    nums[2] = 12
    nums[3] = 18
    var total: Int = 0
    for n in nums:
        total = total + n
    if total == 42:
        return 0
    return total
