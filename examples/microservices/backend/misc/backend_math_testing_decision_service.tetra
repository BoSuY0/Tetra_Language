// Backend math/testing decision microservice smoke.
module examples.microservices.backend.misc.backend_math_testing_decision_service
import lib.core.math as math
import lib.core.testing as testing

func main() -> Int:
    var status: Int = 0
    status = testing.combine(status, testing.assert_eq_i32(math.add_i32(20, 22), 42))
    status = testing.combine(status, testing.assert_eq_i32(math.min_i32(-5, 9), -5))
    status = testing.combine(status, testing.assert_eq_i32(math.max_i32(-5, 9), 9))
    status = testing.combine(status, testing.assert_eq_i32(math.clamp_i32(-99, -10, 10), -10))
    status = testing.combine(status, testing.assert_eq_i32(math.clamp_i32(99, -10, 10), 10))
    status = testing.combine(status, testing.assert_eq_i32(math.clamp_i32(7, -10, 10), 7))
    status = testing.combine(status, testing.assert_true(status == 0))
    status = testing.combine(status, testing.assert_false(false))
    if status != 0:
        return status
    return 0
