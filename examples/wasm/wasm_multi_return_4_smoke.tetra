module examples.wasm.wasm_multi_return_4_smoke

struct Quad:
    a: Int
    b: Int
    c: Int
    d: Int

func make_quad() -> Quad:
    return Quad(a: 5, b: 7, c: 11, d: 19)

func main() -> Int:
    let quad: Quad = make_quad()
    if quad.a + quad.b + quad.c + quad.d == 42:
        return 0
    return 1
