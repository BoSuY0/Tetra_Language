    let name_bounds_status: Int = sb(name_node, release_rect(app, 6))
    let email_label_bounds_status: Int = sb(email_label_node, release_rect(app, 7))
    let email_bounds_status: Int = sb(email_node, release_rect(app, 8))
    let checkbox_bounds_status: Int = sb(checkbox_node, release_rect(app, 9))
    let scroll_bounds_status: Int = sb(scroll_node, release_rect(app, 10))
    let terms_bounds_status: Int = sb(terms_node, release_rect(app, 11))
    let row_bounds_status: Int = sb(row_node, release_rect(app, 12))
    let save_bounds_status: Int = sb(save_node, release_rect(app, 13))
    let reset_bounds_status: Int = sb(reset_node, release_rect(app, 14))
    let spacer_bounds_status: Int = sb(spacer_node, release_rect(app, 15))
    let status_bounds_status: Int = sb(status_node, release_rect(app, 16))
    let root_bounds_group: Int = root_bounds_status + panel_bounds_status + stack_bounds_status
    let form_bounds_group: Int = column_bounds_status + title_bounds_status + desc_bounds_status
    let label_bounds_group: Int = name_label_bounds_status + email_label_bounds_status
    let field_bounds_group: Int = name_bounds_status + email_bounds_status + checkbox_bounds_status
    let scroll_bounds_group: Int = scroll_bounds_status + terms_bounds_status
    let action_bounds_group: Int = row_bounds_status + save_bounds_status + reset_bounds_status
    let tail_bounds_group: Int = spacer_bounds_status + status_bounds_status
    let bounds_left: Int = root_bounds_group + form_bounds_group + label_bounds_group
    let bounds_mid: Int = field_bounds_group + scroll_bounds_group + action_bounds_group
    let initial_node_bounds_status: Int = bounds_left + bounds_mid + tail_bounds_group
    let panel_rect_status: Int = widgets.panel_set_rect(panel, release_rect(app, 0))
    let stack_rect_status: Int = widgets.stack_set_rect(stack, release_rect(app, 1))
    let column_rect_status: Int = widgets.column_set_rect(column, release_rect(app, 2))
    let title_rect_status: Int = widgets.text_set_rect(title, release_rect(app, 3))
    let desc_rect_status: Int = widgets.text_set_rect(description, release_rect(app, 4))
    let name_label_rect_status: Int = widgets.label_set_rect(name_label, release_rect(app, 5))
    let name_rect_status: Int = widgets.textbox_set_rect(name_box, release_rect(app, 6))
    let email_label_rect_status: Int = widgets.label_set_rect(email_label, release_rect(app, 7))
    let email_rect_status: Int = widgets.textbox_set_rect(email_box, release_rect(app, 8))
    let checkbox_rect_status: Int = widgets.checkbox_set_rect(checkbox, release_rect(app, 9))
    let scroll_rect_status: Int = widgets.scroll_set_rect(scroll, release_rect(app, 10))
    let terms_rect_status: Int = widgets.text_set_rect(terms, release_rect(app, 11))
    let row_rect_status: Int = widgets.row_set_rect(row, release_rect(app, 12))
    let save_rect_status: Int = widgets.button_set_rect(save, release_rect(app, 13))
    let reset_rect_status: Int = widgets.button_set_rect(reset, release_rect(app, 14))
    let spacer_rect_status: Int = widgets.spacer_set_rect(spacer, release_rect(app, 15))
    let status_rect_status: Int = widgets.status_text_set_rect(status, release_rect(app, 16))
    let shell_rect_status: Int = panel_rect_status + stack_rect_status + column_rect_status
    let text_rect_status: Int = title_rect_status + desc_rect_status + terms_rect_status
    let label_rect_status: Int = name_label_rect_status + email_label_rect_status
    let field_rect_status: Int = name_rect_status + email_rect_status + checkbox_rect_status
    let scroll_row_rect_status: Int = scroll_rect_status + row_rect_status
    let button_rect_status: Int = save_rect_status + reset_rect_status
    let tail_rect_status: Int = spacer_rect_status + status_rect_status
    let widget_bounds_left: Int = shell_rect_status + text_rect_status + label_rect_status
    let widget_bounds_mid: Int = field_rect_status + scroll_row_rect_status + button_rect_status
    let widget_bounds_total: Int = widget_bounds_left + widget_bounds_mid
    let initial_widget_bounds_status: Int = widget_bounds_total + tail_rect_status
    var win: surface.Surface = surface.open("Surface Release Toolkit", app.width, app.height)
    let name_focus_off: Int = widgets.textbox_set_focus(name_box, false)
    let email_focus_off: Int = widgets.textbox_set_focus(email_box, false)
    let checkbox_focus_off: Int = widgets.checkbox_set_focus(checkbox, false)
    let save_focus_off: Int = widgets.button_set_focus(save, false)
    let reset_focus_off: Int = widgets.button_set_focus(reset, false)
    let field_focus_off: Int = name_focus_off + email_focus_off + checkbox_focus_off
    let action_focus_off: Int = save_focus_off + reset_focus_off
    let focus_status: Int = field_focus_off + action_focus_off
    var before_frame: surface.Frame = surface.begin_frame(win)
    var before_ctx: draw.DrawContext = draw.DrawContext(frame: before_frame)
    let nb0: widgets.TextBox = name_box
    let eb0: widgets.TextBox = email_box
    let cb0: widgets.Checkbox = checkbox
    let sc0: widgets.Scroll = scroll
    let sv0: widgets.Button = save
    let rt0: widgets.Button = reset
    let st0: widgets.StatusText = status
    let bd: Int = draw_release_form_scene(app, nb0, eb0, cb0, sc0, sv0, rt0, st0, before_ctx)
    let first_presented: Int = surface.present(before_ctx.frame)
    var text_bytes: []u8 = core.make_u8(32)
    var path_slots: []i32 = core.make_i32(18)
    var draw_order: []i32 = core.make_i32(18)
    var handled: Int = 0
    var polls: Int = 0
    var target_id: Int = component.focus_none()
    var path_len: Int = 0
    var copied_text_len: Int = 0
    while polls < 20:
        let event: surface.Event = surface.poll_event(win)
        if event.kind == surface.event_none():
            break
        if event.kind == surface.event_close():
            break
        if event.kind == surface.event_mouse_up():
            let x: Int = event.x
            let y: Int = event.y
            if !component.node_hit(root_node, x, y):
                target_id = component.focus_none()
            else if component.node_hit(row_node, x, y):
                if component.node_hit(reset_node, x, y):
                    target_id = reset_node.id
                else if component.node_hit(save_node, x, y):
                    target_id = save_node.id
                else if component.node_hit(status_node, x, y):
                    target_id = status_node.id
                else if component.node_hit(spacer_node, x, y):
                    target_id = spacer_node.id
                else:
                    target_id = row_node.id
            else if component.node_hit(scroll_node, x, y):
                if component.node_hit(terms_node, x, y):
                    target_id = terms_node.id
                else:
                    target_id = scroll_node.id
            else if component.node_hit(checkbox_node, x, y):
                target_id = checkbox_node.id
            else if component.node_hit(email_node, x, y):
                target_id = email_node.id
            else if component.node_hit(email_label_node, x, y):
                target_id = email_label_node.id
            else if component.node_hit(name_node, x, y):
                target_id = name_node.id
            else if component.node_hit(name_label_node, x, y):
                target_id = name_label_node.id
            else if component.node_hit(description_node, x, y):
                target_id = description_node.id
            else if component.node_hit(title_node, x, y):
                target_id = title_node.id
            else if component.node_hit(column_node, x, y):
                target_id = column_node.id
            else if component.node_hit(stack_node, x, y):
                target_id = stack_node.id
            else if component.node_hit(panel_node, x, y):
                target_id = panel_node.id
            else:
                target_id = root_node.id
            path_len = component.tree_build_dispatch_path(app.tree, target_id, path_slots)
            if target_id == name_node.id:
                handled = handled + component.tree_set_focus(app.tree, name_node.id)
            else if target_id == scroll_node.id || target_id == terms_node.id:
                handled = handled + widgets.scroll_set_offset(scroll, 16)
            handled = handled + path_len
        else if event.kind == surface.event_text_input():
            copied_text_len = surface.poll_event_text_into(win, text_bytes)
            if app.tree.focused_id == name_node.id:
                handled = handled + tti(name_box, text_bytes, copied_text_len)
            else if app.tree.focused_id == email_node.id:
                handled = handled + tti(email_box, text_bytes, copied_text_len)
        else if event.kind == surface.event_key_down():
            if event.key == 9:
                let _: Int = component.tree_focus_next(app.tree)
                handled = handled + app.tree.focused_id
            else if app.tree.focused_id == checkbox_node.id:
                handled = handled + widgets.checkbox_key_event(checkbox, event.key)
            else if app.tree.focused_id == save_node.id:
                path_len = component.tree_build_dispatch_path(app.tree, save_node.id, path_slots)
                let save_key_status: Int = widgets.button_key_event(save, event.key)
                if save_key_status > 0:
                    app.save_count = app.save_count + 1
                    app.status_code = 1
                    handled = handled + widgets.status_text_set_status(status, app.status_code)
                handled = handled + path_len + save_key_status
            else if app.tree.focused_id == reset_node.id:
                path_len = component.tree_build_dispatch_path(app.tree, reset_node.id, path_slots)
                let reset_key_status: Int = widgets.button_key_event(reset, event.key)
                if reset_key_status > 0:
                    app.reset_count = app.reset_count + 1
                    app.status_code = 2
                    handled = handled + widgets.status_text_set_status(status, app.status_code)
                    handled = handled + widgets.textbox_clear(name_box)
                    handled = handled + widgets.textbox_clear(email_box)
                handled = handled + path_len + reset_key_status
        else if event.kind == surface.event_resize():
            app.width = event.width
            app.height = event.height
            handled = handled + app.width + app.height
            let rz_root_bounds: Int = sb(root_node, release_rect(app, 0))
            let rz_panel_bounds: Int = sb(panel_node, release_rect(app, 0))
            let rz_stack_bounds: Int = sb(stack_node, release_rect(app, 1))
            let rz_column_bounds: Int = sb(column_node, release_rect(app, 2))
            let rz_title_bounds: Int = sb(title_node, release_rect(app, 3))
            let rz_desc_bounds: Int = sb(description_node, release_rect(app, 4))
            let rz_name_label_bounds: Int = sb(name_label_node, release_rect(app, 5))
            let rz_name_bounds: Int = sb(name_node, release_rect(app, 6))
            let rz_email_label_bounds: Int = sb(email_label_node, release_rect(app, 7))
            let rz_email_bounds: Int = sb(email_node, release_rect(app, 8))
            let rz_checkbox_bounds: Int = sb(checkbox_node, release_rect(app, 9))
            let rz_scroll_bounds: Int = sb(scroll_node, release_rect(app, 10))
            let rz_terms_bounds: Int = sb(terms_node, release_rect(app, 11))
            let rz_row_bounds: Int = sb(row_node, release_rect(app, 12))
            let rz_save_bounds: Int = sb(save_node, release_rect(app, 13))
            let rz_reset_bounds: Int = sb(reset_node, release_rect(app, 14))
            let rz_spacer_bounds: Int = sb(spacer_node, release_rect(app, 15))
            let rz_status_bounds: Int = sb(status_node, release_rect(app, 16))
            let rz_root_group: Int = rz_root_bounds + rz_panel_bounds + rz_stack_bounds
            let rz_form_group: Int = rz_column_bounds + rz_title_bounds + rz_desc_bounds
            let rz_label_group: Int = rz_name_label_bounds + rz_email_label_bounds
            let rz_field_group: Int = rz_name_bounds + rz_email_bounds + rz_checkbox_bounds
            let rz_scroll_group: Int = rz_scroll_bounds + rz_terms_bounds
            let rz_action_group: Int = rz_row_bounds + rz_save_bounds + rz_reset_bounds
            let rz_tail_group: Int = rz_spacer_bounds + rz_status_bounds
            let rz_bounds_left: Int = rz_root_group + rz_form_group + rz_label_group
            let rz_bounds_mid: Int = rz_field_group + rz_scroll_group + rz_action_group
            handled = handled + rz_bounds_left + rz_bounds_mid + rz_tail_group
            let rz_panel_rect: Int = widgets.panel_set_rect(panel, release_rect(app, 0))
            let rz_stack_rect: Int = widgets.stack_set_rect(stack, release_rect(app, 1))
            let rz_column_rect: Int = widgets.column_set_rect(column, release_rect(app, 2))
            let rz_title_rect: Int = widgets.text_set_rect(title, release_rect(app, 3))
            let rz_desc_rect: Int = widgets.text_set_rect(description, release_rect(app, 4))
            let rz_name_label_rect: Int = widgets.label_set_rect(name_label, release_rect(app, 5))
            let rz_name_rect: Int = widgets.textbox_set_rect(name_box, release_rect(app, 6))
            let rz_email_label_rect: Int = widgets.label_set_rect(email_label, release_rect(app, 7))
            let rz_email_rect: Int = widgets.textbox_set_rect(email_box, release_rect(app, 8))
            let rz_checkbox_rect: Int = widgets.checkbox_set_rect(checkbox, release_rect(app, 9))
            let rz_scroll_rect: Int = widgets.scroll_set_rect(scroll, release_rect(app, 10))
            let rz_terms_rect: Int = widgets.text_set_rect(terms, release_rect(app, 11))
            let rz_row_rect: Int = widgets.row_set_rect(row, release_rect(app, 12))
            let rz_save_rect: Int = widgets.button_set_rect(save, release_rect(app, 13))
            let rz_reset_rect: Int = widgets.button_set_rect(reset, release_rect(app, 14))
            let rz_spacer_rect: Int = widgets.spacer_set_rect(spacer, release_rect(app, 15))
            let rz_status_rect: Int = widgets.status_text_set_rect(status, release_rect(app, 16))
            let rz_shell_rect: Int = rz_panel_rect + rz_stack_rect + rz_column_rect
            let rz_text_rect: Int = rz_title_rect + rz_desc_rect + rz_terms_rect
            let rz_label_rect: Int = rz_name_label_rect + rz_email_label_rect
            let rz_field_rect: Int = rz_name_rect + rz_email_rect + rz_checkbox_rect
            let rz_scroll_row_rect: Int = rz_scroll_rect + rz_row_rect
            let rz_button_rect: Int = rz_save_rect + rz_reset_rect
            let rz_tail_rect: Int = rz_spacer_rect + rz_status_rect
            let rz_widget_left: Int = rz_shell_rect + rz_text_rect + rz_label_rect
            let rz_widget_mid: Int = rz_field_rect + rz_scroll_row_rect + rz_button_rect
            handled = handled + rz_widget_left + rz_widget_mid + rz_tail_rect
        let name_focused: Bool = app.tree.focused_id == name_node.id
        let email_focused: Bool = app.tree.focused_id == email_node.id
        let checkbox_focused: Bool = app.tree.focused_id == checkbox_node.id
        let save_focused: Bool = app.tree.focused_id == save_node.id
        let reset_focused: Bool = app.tree.focused_id == reset_node.id
        handled = handled + widgets.textbox_set_focus(name_box, name_focused)
        handled = handled + widgets.textbox_set_focus(email_box, email_focused)
        handled = handled + widgets.checkbox_set_focus(checkbox, checkbox_focused)
        handled = handled + widgets.button_set_focus(save, save_focused)
        handled = handled + widgets.button_set_focus(reset, reset_focused)
        polls = polls + 1
    if app.width < 560:
        app.width = 560
        app.height = 420
        let fb_root_bounds: Int = sb(root_node, release_rect(app, 0))
        let fb_panel_bounds: Int = sb(panel_node, release_rect(app, 0))
        let fb_stack_bounds: Int = sb(stack_node, release_rect(app, 1))
        let fb_column_bounds: Int = sb(column_node, release_rect(app, 2))
        let fb_title_bounds: Int = sb(title_node, release_rect(app, 3))
        let fb_desc_bounds: Int = sb(description_node, release_rect(app, 4))
        let fb_name_label_bounds: Int = sb(name_label_node, release_rect(app, 5))
        let fb_name_bounds: Int = sb(name_node, release_rect(app, 6))
        let fb_email_label_bounds: Int = sb(email_label_node, release_rect(app, 7))
        let fb_email_bounds: Int = sb(email_node, release_rect(app, 8))
        let fb_checkbox_bounds: Int = sb(checkbox_node, release_rect(app, 9))
        let fb_scroll_bounds: Int = sb(scroll_node, release_rect(app, 10))
        let fb_terms_bounds: Int = sb(terms_node, release_rect(app, 11))
        let fb_row_bounds: Int = sb(row_node, release_rect(app, 12))
        let fb_save_bounds: Int = sb(save_node, release_rect(app, 13))
        let fb_reset_bounds: Int = sb(reset_node, release_rect(app, 14))
        let fb_spacer_bounds: Int = sb(spacer_node, release_rect(app, 15))
        let fb_status_bounds: Int = sb(status_node, release_rect(app, 16))
        let fb_root_group: Int = fb_root_bounds + fb_panel_bounds + fb_stack_bounds
        let fb_form_group: Int = fb_column_bounds + fb_title_bounds + fb_desc_bounds
        let fb_label_group: Int = fb_name_label_bounds + fb_email_label_bounds
        let fb_field_group: Int = fb_name_bounds + fb_email_bounds + fb_checkbox_bounds
        let fb_scroll_group: Int = fb_scroll_bounds + fb_terms_bounds
        let fb_action_group: Int = fb_row_bounds + fb_save_bounds + fb_reset_bounds
        let fb_tail_group: Int = fb_spacer_bounds + fb_status_bounds
        let fb_bounds_left: Int = fb_root_group + fb_form_group + fb_label_group
        let fb_bounds_mid: Int = fb_field_group + fb_scroll_group + fb_action_group
        handled = handled + fb_bounds_left + fb_bounds_mid + fb_tail_group
        let fb_panel_rect: Int = widgets.panel_set_rect(panel, release_rect(app, 0))
        let fb_stack_rect: Int = widgets.stack_set_rect(stack, release_rect(app, 1))
        let fb_column_rect: Int = widgets.column_set_rect(column, release_rect(app, 2))
        let fb_title_rect: Int = widgets.text_set_rect(title, release_rect(app, 3))
        let fb_desc_rect: Int = widgets.text_set_rect(description, release_rect(app, 4))
        let fb_name_label_rect: Int = widgets.label_set_rect(name_label, release_rect(app, 5))
        let fb_name_rect: Int = widgets.textbox_set_rect(name_box, release_rect(app, 6))
        let fb_email_label_rect: Int = widgets.label_set_rect(email_label, release_rect(app, 7))
        let fb_email_rect: Int = widgets.textbox_set_rect(email_box, release_rect(app, 8))
        let fb_checkbox_rect: Int = widgets.checkbox_set_rect(checkbox, release_rect(app, 9))
        let fb_scroll_rect: Int = widgets.scroll_set_rect(scroll, release_rect(app, 10))
        let fb_terms_rect: Int = widgets.text_set_rect(terms, release_rect(app, 11))
        let fb_row_rect: Int = widgets.row_set_rect(row, release_rect(app, 12))
        let fb_save_rect: Int = widgets.button_set_rect(save, release_rect(app, 13))
        let fb_reset_rect: Int = widgets.button_set_rect(reset, release_rect(app, 14))
        let fb_spacer_rect: Int = widgets.spacer_set_rect(spacer, release_rect(app, 15))
        let fb_status_rect: Int = widgets.status_text_set_rect(status, release_rect(app, 16))
