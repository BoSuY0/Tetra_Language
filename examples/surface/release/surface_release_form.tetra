    let reset_init_status: Int = widgets.button_init(reset, empty_rect, widgets.action_reset())
    let spacer_init_status: Int = widgets.spacer_init(spacer, empty_rect, spacer_size)
    let status_init_status: Int = widgets.status_text_init(status, empty_rect, 6, 0)
