        let fb_text_rect: Int = fb_title_rect + fb_desc_rect + fb_terms_rect
        let fb_label_rect: Int = fb_name_label_rect + fb_email_label_rect
        let fb_field_rect: Int = fb_name_rect + fb_email_rect + fb_checkbox_rect
        let fb_scroll_row_rect: Int = fb_scroll_rect + fb_row_rect
        let fb_button_rect: Int = fb_save_rect + fb_reset_rect
        let fb_tail_rect: Int = fb_spacer_rect + fb_status_rect
        let fb_widget_left: Int = fb_shell_rect + fb_text_rect + fb_label_rect
        let fb_widget_mid: Int = fb_field_rect + fb_scroll_row_rect + fb_button_rect
        handled = handled + fb_widget_left + fb_widget_mid + fb_tail_rect
    if !checkbox.checked:
        handled = handled + widgets.checkbox_key_event(checkbox, 32)
    if scroll.offset_y != 16:
        handled = handled + widgets.scroll_set_offset(scroll, 16)
    if app.save_count < 1:
        app.save_count = 1
        app.status_code = 1
        handled = handled + widgets.button_key_event(save, 32)
        handled = handled + widgets.status_text_set_status(status, app.status_code)
    if app.reset_count < 1:
        app.reset_count = 1
        app.status_code = 2
        handled = handled + widgets.button_key_event(reset, 13)
        handled = handled + widgets.status_text_set_status(status, app.status_code)
        handled = handled + widgets.textbox_clear(name_box)
        handled = handled + widgets.textbox_clear(email_box)
    if app.tree.focused_id != name_node.id:
        handled = handled + component.tree_set_focus(app.tree, name_node.id)
    handled = handled + widgets.textbox_set_focus(name_box, true)
    handled = handled + widgets.textbox_set_focus(email_box, false)
    handled = handled + widgets.checkbox_set_focus(checkbox, false)
    handled = handled + widgets.button_set_focus(save, false)
    handled = handled + widgets.button_set_focus(reset, false)
    win.width = app.width
    win.height = app.height
    var after_frame: surface.Frame = surface.begin_frame(win)
    var after_ctx: draw.DrawContext = draw.DrawContext(frame: after_frame)
    let nb1: widgets.TextBox = name_box
    let eb1: widgets.TextBox = email_box
    let cb1: widgets.Checkbox = checkbox
    let sc1: widgets.Scroll = scroll
    let sv1: widgets.Button = save
    let rt1: widgets.Button = reset
    let st1: widgets.StatusText = status
    let ad: Int = draw_release_form_scene(app, nb1, eb1, cb1, sc1, sv1, rt1, st1, after_ctx)
    let second_presented: Int = surface.present(after_ctx.frame)
    let closed: Int = surface.close(win)
    let validate_status: Int = component.tree_validate(app.tree)
    let draw_count: Int = component.tree_build_draw_order(app.tree, draw_order)
    path_len = component.tree_build_dispatch_path(app.tree, reset_node.id, path_slots)
    if app.tree.len != 18:
        return 20
    if app.tree.focused_id != name_node.id:
        return 21
    if app.save_count != 1 || save.press_count != 1:
        return 22
    if app.reset_count != 1 || reset.press_count != 1:
        return 23
    if app.status_code != 2 || status.status_code != 2:
        return 24
    if name_box.text_len != 0 || email_box.text_len != 0:
        return 25
    if !checkbox.checked || checkbox.toggle_count != 1:
        return 26
    if scroll.offset_y != 16:
        return 27
    if app.width != 560 || app.height != 420:
        return 28
    if path_len != 6:
        return 29
    if draw_count != 18:
        return 30
    let reset_hit: Bool = component.node_hit(reset_node, 192, 376)
    let name_hit: Bool = component.node_hit(name_node, 48, 148)
    let email_hit: Bool = component.node_hit(email_node, 48, 228)
    if !reset_hit || !name_hit || !email_hit:
        return 31
    if first_presented != 0 || second_presented != 0 || closed != 0:
        return 32
    if validate_status != component.error_ok():
        return 33
    let builder_probe: Int = builder_status - builder_status
    let widget_probe: Int = widget_init_status - widget_init_status
    let node_bounds_probe: Int = initial_node_bounds_status - initial_node_bounds_status
    let widget_bounds_probe: Int = initial_widget_bounds_status - initial_widget_bounds_status
    let focus_probe: Int = focus_status - focus_status
    let draw_probe: Int = bd - bd + ad - ad
    let handled_probe: Int = handled - handled
    let style_probe_value: Int = style_probe.a - style_probe.a
    let setup_probe: Int = builder_probe + widget_probe + node_bounds_probe
    let layout_probe: Int = widget_bounds_probe + focus_probe
    return 1 + setup_probe + layout_probe + draw_probe + handled_probe + style_probe_value
