module examples.safe_view_copy_escape

func owned(xs: borrow []u8) -> []u8
uses alloc, mem:
    let borrowed: []u8 = __method.borrow(xs.window(1, 2))
    return borrowed.copy()

func main() -> Int
uses alloc, mem:
    var xs: []u8 = make_u8(4)
    xs[1] = 20
    xs[2] = 22
    let copied: []u8 = owned(xs)
    xs[1] = 99
    if copied[0] + copied[1] == 42:
        return 0
    return copied[0] + copied[1]
