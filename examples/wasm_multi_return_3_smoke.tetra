module examples.wasm_multi_return_3_smoke

enum Packet:
    case data(Int, Int)
    case empty

func make_packet() -> Packet:
    return Packet.data(17, 25)

func main() -> Int:
    let packet: Packet = make_packet()
    let score: Int = match packet:
    case Packet.data(left, right):
        left + right
    case Packet.empty:
        0
    if score == 42:
        return 0
    return 1
