module examples.memory.safe_view.safe_view_borrow_return

func main() -> Int
uses alloc, mem:
    var xs: []u8 = make_u8(4)
    xs[0] = 1
    xs[1] = 20
    xs[2] = 22
    xs[3] = 99
    let v: []u8 = __method.borrow(xs.window(1, 2))
    if v[0] + v[1] == 42:
        return 0
    return v[0] + v[1]
