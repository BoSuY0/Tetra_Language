module examples.memory.safe_view.safe_view_aggregate_copy_escape

struct Box:
    bytes: []u8

func boxed(xs: borrow []u8) -> Box
uses alloc, mem:
    return Box(bytes: __method.copy(xs.window(1, 2)))

func main() -> Int
uses alloc, mem:
    var xs: []u8 = make_u8(4)
    xs[1] = 20
    xs[2] = 22
    let box: Box = boxed(xs)
    if box.bytes[0] + box.bytes[1] == 42:
        return 0
    return box.bytes[0] + box.bytes[1]
