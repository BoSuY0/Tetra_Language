// Are-We-Fast-Yet-inspired function value dispatch kernel.
module examples.benchmarks.awfy_closure_dispatch

func apply(cb: fn(Int) -> Int, value: Int) -> Int:
    return cb(value)

func main() -> Int:
    let bias: Int = 3
    let step: fn(Int) -> Int = fn(value: Int) -> Int:
        return value * 2 + bias
    var i: Int = 0
    var total: Int = 0
    while i < 16:
        total = total + apply(step, i)
        i = i + 1
    if total == 288:
        return 0
    return total
