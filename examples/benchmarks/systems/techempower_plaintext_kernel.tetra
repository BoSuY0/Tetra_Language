// TechEmpower-inspired plaintext response accounting kernel.
module examples.benchmarks.systems.techempower_plaintext_kernel

func response_cost(index: Int) -> Int:
    return 200 + 13 + 24 + index % 7

func main() -> Int:
    var i: Int = 0
    var total: Int = 0
    while i < 64:
        total = total + response_cost(i)
        i = i + 1
    if total == 15357:
        return 0
    return total % 251
