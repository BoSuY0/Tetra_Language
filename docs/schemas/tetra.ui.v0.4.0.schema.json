{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tetra.ui.v0.4.0.schema.json",
  "title": "Tetra UI metadata bundle v0.4.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "states",
    "views"
  ],
  "properties": {
    "schema": {
      "const": "tetra.ui.v0.4.0"
    },
    "states": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/state"
      }
    },
    "views": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/view"
      }
    }
  },
  "$defs": {
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "module",
        "fields"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "module": {
          "type": "string"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stateField"
          }
        }
      }
    },
    "stateField": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "mutable",
        "const",
        "init"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "mutable": {
          "type": "boolean"
        },
        "const": {
          "type": "boolean"
        },
        "init": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "view": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "module",
        "state_type",
        "bindings",
        "events",
        "commands",
        "styles",
        "accessibility"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "module": {
          "type": "string"
        },
        "state_type": {
          "type": "string",
          "minLength": 1
        },
        "bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/binding"
          }
        },
        "events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/event"
          }
        },
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command"
          }
        },
        "styles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/typedValue"
          }
        },
        "accessibility": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/typedValue"
          }
        }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "source"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "command"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "statement_count"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "statement_count": {
          "type": "integer",
          "minimum": 0
        },
        "operations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/commandOperation"
          }
        }
      }
    },
    "commandOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "target"
      ],
      "properties": {
        "kind": {
          "enum": [
            "state_add",
            "state_set"
          ]
        },
        "target": {
          "type": "string",
          "pattern": "^state\\.[A-Za-z_][A-Za-z0-9_]*$"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "typedValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
