@export("__tetra_time_now_ms")
func rt_time_now_ms() -> i32:
    return g_time_ms

@export("__tetra_sleep_ms")
func rt_sleep_ms(ms: i32) -> i32:
    unsafe:
        if ms > 0:
            var mem: cap.mem = core.cap_mem()
            var wake: i32 = g_time_ms + ms
            var _stored: i32 = set_actor_wake_ms(g_current, wake)
            var _status: i32 = set_actor_status(g_current, STATUS_SLEEPING)
            var _yield: i32 = core.ctx_switch(actor_slot(g_current), g_sched_slot, mem)
    return 0

@export("__tetra_sleep_until_ms")
func rt_sleep_until_ms(deadline: i32) -> i32:
    unsafe:
        var until: i32 = deadline
        if until < 0:
            until = 0
        if until > g_time_ms:
            var mem: cap.mem = core.cap_mem()
            var _stored: i32 = set_actor_wake_ms(g_current, until)
            var _status: i32 = set_actor_status(g_current, STATUS_SLEEPING)
            var _yield: i32 = core.ctx_switch(actor_slot(g_current), g_sched_slot, mem)
    return 0

@export("__tetra_deadline_ms")
func rt_deadline_ms(delta: i32) -> i32:
    if delta > 0:
        return g_time_ms + delta
    return g_time_ms

@export("__tetra_timer_ready_ms")
func rt_timer_ready_ms(deadline: i32) -> bool:
    var until: i32 = deadline
    if until < 0:
        until = 0
    return g_time_ms >= until
